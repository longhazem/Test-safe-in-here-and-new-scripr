    lockBtn.Image = "rbxassetid://10734950309"
    lockBtn.ImageColor3 = Color3.fromRGB(200, 200, 200)
    lockBtn.ZIndex = 16

    local closeBtn = Instance.new("TextButton", toolContainer)
    closeBtn.Size = UDim2.new(0, 26, 0, 26)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Text = "×"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.TextSize = 28
    closeBtn.ZIndex = 16

    lockBtn.MouseButton1Click:Connect(function()
        PlayCustomClick()
        _G.UILocked = not _G.UILocked
        TweenService:Create(lockBtn, TweenInfo.new(0.2), {
            ImageColor3 = _G.UILocked and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(200, 200, 200)
        }):Play()
    end)

    closeBtn.MouseButton1Click:Connect(function()
        PlayCustomClick()
        TweenService:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)}):Play()
        task.delay(0.4, function() main.Visible = false; openBtn.Visible = true end)
    end)

    local tabArea = Instance.new("ScrollingFrame", container)
    tabArea.Size = UDim2.new(1, -30, 0, 38)
    tabArea.Position = UDim2.new(0, 15, 0, 45)
    tabArea.BackgroundTransparency = 1
    tabArea.ScrollBarThickness = 0
    tabArea.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabArea.AutomaticCanvasSize = Enum.AutomaticSize.X
    tabArea.ZIndex = 11
    local tabLayout = Instance.new("UIListLayout", tabArea)
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.Padding = UDim.new(0, 10)
    tabLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    local pages = Instance.new("Frame", container)
    pages.Size = UDim2.new(1, -30, 1, -100)
    pages.Position = UDim2.new(0, 15, 0, 90)
    pages.BackgroundTransparency = 1
    pages.ZIndex = 20

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local input = searchBox.Text:lower()
        for _, pg in pairs(pages:GetChildren()) do
            if pg:IsA("ScrollingFrame") then
                for _, el in pairs(pg:GetChildren()) do
                    if el:IsA("TextButton") or el:IsA("TextLabel") then
                        local content = el:FindFirstChildOfClass("TextLabel") and el:FindFirstChildOfClass("TextLabel").Text or el.Text
                        el.Visible = content:lower():find(input) and true or false
                    end
                end
            end
        end
    end)

    local firstTab = true
    function Library:CreateTab(name)
        local page = Instance.new("ScrollingFrame", pages)
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        page.ZIndex = 21
        local pageLayout = Instance.new("UIListLayout", page)
        pageLayout.Padding = UDim.new(0, 8)
        pageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

        local tabBtn = Instance.new("TextButton", tabArea)
        tabBtn.Size = UDim2.new(0, 95, 0, 32)
        tabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        tabBtn.BackgroundTransparency = 0.3
        tabBtn.Text = name
        tabBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
        tabBtn.Font = Enum.Font.GothamSemibold
        tabBtn.TextSize = 13
        tabBtn.ZIndex = 15
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, 8)
        local tabStroke = Instance.new("UIStroke", tabBtn)
        tabStroke.Thickness = 1.2
        tabStroke.Transparency = 1
        tabStroke.Color = Color3.fromRGB(255, 255, 255)

        tabBtn.MouseButton1Click:Connect(function()
            PlayCustomClick()
            for _, v in pairs(pages:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(tabArea:GetChildren()) do 
                if v:IsA("TextButton") then 
                    v.TextColor3 = Color3.fromRGB(160, 160, 160)
                    v:FindFirstChildOfClass("UIStroke").Transparency = 1
                end 
            end
            page.Visible = true
            tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            tabStroke.Transparency = 0
        end)

        if firstTab then
            task.delay(0.1, function() page.Visible = true; tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255); tabStroke.Transparency = 0 end)
            firstTab = false
        end

        local elements = {}
        function elements:AddSection(text)
            local sectionLbl = Instance.new("TextLabel", page)
            sectionLbl.Size = UDim2.new(1, -10, 0, 25)
            sectionLbl.BackgroundTransparency = 1
            sectionLbl.Text = text
            sectionLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
            sectionLbl.Font = Enum.Font.GothamBold
            sectionLbl.TextSize = 13
            sectionLbl.TextXAlignment = Enum.TextXAlignment.Left
        end

        function elements:AddToggle(text, callback)
            local toggleFrame = Instance.new("TextButton", page)
            toggleFrame.Size = UDim2.new(1, -4, 0, 45)
            toggleFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            toggleFrame.BackgroundTransparency = 0.2
            toggleFrame.Text = ""
            toggleFrame.ZIndex = 25
            Instance.new("UICorner", toggleFrame).CornerRadius = UDim.new(0, 8)
            local label = Instance.new("TextLabel", toggleFrame)
            label.Size = UDim2.new(1, -70, 1, 0)
            label.Position = UDim2.new(0, 15, 0, 0)
            label.BackgroundTransparency = 1
            label.Text = text
            label.TextColor3 = Color3.fromRGB(255, 255, 255)
            label.Font = Enum.Font.GothamSemibold
            label.TextSize = 14
            label.TextXAlignment = Enum.TextXAlignment.Left
            local tglBg = Instance.new("Frame", toggleFrame)
            tglBg.Size = UDim2.new(0, 42, 0, 22)
            tglBg.Position = UDim2.new(1, -55, 0.5, -11)
            tglBg.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
            Instance.new("UICorner", tglBg).CornerRadius = UDim.new(1, 0)
            local tglDot = Instance.new("Frame", tglBg)
            tglDot.Size = UDim2.new(0, 18, 0, 18)
            tglDot.Position = UDim2.new(0, 2, 0.5, -9)
            tglDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Instance.new("UICorner", tglDot).CornerRadius = UDim.new(1, 0)
            local enabled = _G.TokaiConfig[name.."_"..text] or false
            local function update()
                TweenService:Create(tglDot, TweenInfo.new(0.25, Enum.EasingStyle.Quart), {Position = enabled and UDim2.new(0, 22, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)}):Play()
                TweenService:Create(tglBg, TweenInfo.new(0.25), {BackgroundColor3 = enabled and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(65, 65, 65)}):Play()
            end
            update()
            toggleFrame.MouseButton1Click:Connect(function() PlayCustomClick(); enabled = not enabled; _G.TokaiConfig[name.."_"..text] = enabled; update(); callback(enabled) end)
        end

        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.Size = UDim2.new(1, -4, 0, 45)
            btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            btn.BackgroundTransparency = 0.2
            btn.Text = "  " .. text
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Font = Enum.Font.GothamSemibold
            btn.TextSize = 14
            btn.TextXAlignment = Enum.TextXAlignment.Left
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
            btn.MouseButton1Click:Connect(function() PlayCustomClick(); callback() end)
        end
        return elements
    end

    local function Drag(obj)
        local dragging, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if not _G.UILocked and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                dragging = true; dragStart = input.Position; startPos = obj.Position
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStart
                obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
        UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end end)
    end
    Drag(main); Drag(openBtn)

    openBtn.MouseButton1Click:Connect(function() PlayCustomClick(); openBtn.Visible = false; main.Visible = true; main.Position = UDim2.new(0.5, 0, 0.5, 0); TweenService:Create(main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = mainSize}):Play() end)

    coroutine.wrap(function()
        local h = 0
        while screenGui.Parent do
            h = h + 1/500; local c = Color3.fromHSV(h%1, 0.7, 1)
            neonStroke.Color = c; glowFrame.ImageColor3 = c; openStroke.Color = c
            RunService.RenderStepped:Wait()
        end
    end)()

    return Library
end

