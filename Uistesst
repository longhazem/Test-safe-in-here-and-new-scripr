    local searchBox = Instance.new("TextBox", toolContainer)
    searchBox.Size = UDim2.new(0, 130, 0, 26)
    searchBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    searchBox.BackgroundTransparency = 0.3
    searchBox.Text = ""
    searchBox.PlaceholderText = "Search features..."
    searchBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    searchBox.PlaceholderColor3 = Color3.fromRGB(180, 180, 180)
    searchBox.Font = Enum.Font.Gotham
    searchBox.TextSize = 12
    searchBox.ZIndex = 16
    Instance.new("UICorner", searchBox).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", searchBox).Color = Color3.fromRGB(80, 80, 80)

    local lockBtn = Instance.new("ImageButton", toolContainer)
    lockBtn.Size = UDim2.new(0, 24, 0, 24)
