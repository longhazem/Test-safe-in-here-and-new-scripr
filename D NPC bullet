local Players = game:GetService('Players')
local Workspace = game:GetService('Workspace')
local LocalPlayer = Players.LocalPlayer

local Camera = Workspace.CurrentCamera
local CenterPosition = Camera.ViewportSize / 2

local Drawings = {FovOutline = nil, FovInline = nil}

-- Chỉ giữ lại các hàm cần thiết cho súng (Muzzle và Recoil)
local Functions = {
    GetMuzzleCFrame = filtergc('function', {Name = 'GetMuzzleCFrame'}, true),
    GetRecoil = filtergc('function', {Name = 'getRecoil'}, true)
}

function AddDrawing(Type, Properties)
    local DrawingObject = Drawing.new(Type)
    for Property, Value in pairs(Properties) do
        DrawingObject[Property] = Value
    end
    return DrawingObject
end

-- Đổi sang tìm NPC trong Workspace
function GetClosestNPC()
    local ClosestNPC, ClosestDistance = nil, math.huge

    -- Quét tất cả mọi thứ trong Workspace (Nếu game có thư mục chứa NPC riêng, ví dụ Workspace.Enemies, hãy đổi Workspace thành Workspace.Enemies)
    for _, Entity in pairs(Workspace:GetDescendants()) do
        -- Kiểm tra xem nó có phải là 1 nhân vật không (Có Model, Humanoid và Head)
        if Entity:IsA("Model") and Entity:FindFirstChild("Humanoid") and Entity:FindFirstChild("Head") then
            
            -- Bỏ qua nếu đó là người chơi thật (Players)
            if Players:GetPlayerFromCharacter(Entity) then continue end
            
            -- Bỏ qua nếu NPC đã chết
            if Entity.Humanoid.Health <= 0 then continue end

            -- [QUAN TRỌNG]: Lọc "NPC male" dựa vào tên. 
            -- Hàm này sẽ bỏ qua nếu trong tên của NPC không có chữ "male" (không phân biệt hoa thường). 
            -- Nếu NPC của bạn có tên khác (vd: "Boy", "Man", "Zom"), hãy đổi chữ "male" thành chữ đó, hoặc xoá dòng này đi nếu muốn target mọi NPC.
            if not string.find(string.lower(Entity.Name), "male") then continue end

            local Head = Entity.Head
            local Position, OnScreen = Camera:WorldToViewportPoint(Head.Position)
            
            if not OnScreen then continue end

            local Distance = (Vector2.new(Position.X, Position.Y) - CenterPosition).Magnitude
            if Distance > 180 or Distance > ClosestDistance then continue end

            ClosestNPC = Entity
            ClosestDistance = Distance
        end
    end
    
    return ClosestNPC
end

-- Vẽ FOV
Drawings.FovOutline = AddDrawing('Circle', {Visible = false, Position = CenterPosition, Radius = 180, Thickness = 0.5, Color = Color3.new(0, 0, 0)})
Drawings.FovInline = AddDrawing('Circle', {Visible = false, Position = CenterPosition, Radius = 180, Thickness = 0.5, Color = Color3.new(1, 1, 1)})

-- Hook Muzzle CFrame (Đường đạn bay)
local OldMuzzle; OldMuzzle = hookfunction(Functions.GetMuzzleCFrame, function(Self, Cast)
    local Origin, Barrel, Camera = OldMuzzle(Self, Cast)

    if not Cast and Origin then
        -- Tìm NPC gần nhất thay vì Player
        local TargetNPC = GetClosestNPC()
        if not TargetNPC then return Origin, Barrel, Camera end
        
        -- Chuyển hướng đạn vào đầu (Head) của NPC
        local NewOrigin = CFrame.new(Origin.Position, TargetNPC.Head.Position)
        return NewOrigin, Barrel, Camera
    end

    return Origin, Barrel, Camera
end)

-- Hook Recoil (Giảm giật)
local OldRecoil; OldRecoil = hookfunction(Functions.GetRecoil, function(...)
    local Args = {...}
    
    Args[1]['Barrel_Spread'] = 0 
    Args[1]['RecoilForce_Tap'] = 0

    return OldRecoil(unpack(Args))
end)

-- Cập nhật lại tâm màn hình khi thay đổi kích thước cửa sổ
Camera:GetPropertyChangedSignal('ViewportSize'):Connect(function()
    CenterPosition = Camera.ViewportSize / 2
end)
