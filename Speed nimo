-- ==========================================
-- 2. LOGIC TƯƠNG TÁC UI (KÉO THẢ, CLICK)
-- ==========================================
-- Logic Kéo thả UI (Draggable)
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Logic Nút Bật/Tắt
ToggleBtn.MouseButton1Click:Connect(function()
    WalkSpeedState.Enabled = not WalkSpeedState.Enabled
    if WalkSpeedState.Enabled then
        ToggleBtn.Text = "Status: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Màu xanh
    else
        ToggleBtn.Text = "Status: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Màu đỏ
    end
end)

-- Logic Thanh kéo (Slider)
local draggingSlider = false
local minSpeed = 16
local maxSpeed = 200

local function updateSlider(input)
    local pos = math.clamp((input.Position.X - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
    SliderFill.Size = UDim2.new(pos, 0, 1, 0)
    
    local newSpeed = math.floor(minSpeed + (maxSpeed - minSpeed) * pos)
    WalkSpeedState.Speed = newSpeed
    SliderText.Text = "Speed: " .. newSpeed
end

SliderBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingSlider = true
        updateSlider(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingSlider = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(input)
    end
end)

-- Cập nhật thanh trượt ban đầu
SliderFill.Size = UDim2.new((WalkSpeedState.Speed - minSpeed) / (maxSpeed - minSpeed), 0, 1, 0)


-- ==========================================
-- 3. LOGIC HACK WALKSPEED (HOOK)
-- ==========================================
local CharControllerMod = findModule("CharacterController")

if CharControllerMod then
    local CharController = require(CharControllerMod)

    -- Lưu lại hàm Update gốc của game
    if not getgenv().OldCharUpdate then
        getgenv().OldCharUpdate = CharController.Update
    end

    -- Ghi đè hàm Update
    CharController.Update = function(self, dt, ...)
        -- Chạy hàm gốc của game trước
        local result = getgenv().OldCharUpdate(self, dt, ...)

        -- Can thiệp nếu người dùng bật WalkSpeed
        if WalkSpeedState.Enabled and LocalPlayer.Character then
            local character = LocalPlayer.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")

            -- Nếu nhân vật tồn tại, còn sống và đang cố di chuyển
            if humanoid and hrp and humanoid.Health > 0 and humanoid.MoveDirection.Magnitude > 0 then
                -- Tốc độ cộng thêm = Tốc độ mục tiêu - Tốc độ mặc định của game (khoảng 16)
                local extraSpeed = WalkSpeedState.Speed - 16
                
                if extraSpeed > 0 then
                    -- Đẩy nhân vật bằng CFrame (nhân với dt để không bị giật lag khung hình)
                    hrp.CFrame = hrp.CFrame + (humanoid.MoveDirection * (extraSpeed * dt))
                end
            end
        end

        return result
    end
else
    warn("Không tìm thấy module CharacterController. Hãy chắc chắn bạn đang ở trong game BRM5.")
end

print("Đã tải xong BRM5 WalkSpeed UI!")
