-- ==========================================
-- 2. LOGIC ĐIỀU KHIỂN
-- ==========================================
Toggle.MouseButton1Click:Connect(function()
    getgenv().SpeedHack.Enabled = not getgenv().SpeedHack.Enabled
    Toggle.Text = getgenv().SpeedHack.Enabled and "TRẠNG THÁI: BẬT" or "TRẠNG THÁI: TẮT"
    Toggle.BackgroundColor3 = getgenv().SpeedHack.Enabled and Color3.fromRGB(50, 180, 50) or Color3.fromRGB(180, 50, 50)
end)

SpeedInput.FocusLost:Connect(function()
    local val = tonumber(SpeedInput.Text)
    if val then getgenv().SpeedHack.Value = val else SpeedInput.Text = tostring(getgenv().SpeedHack.Value) end
end)

-- ==========================================
-- 3. HOOK CHARACTER CONTROLLER (CƠ CHẾ CHÍNH)
-- ==========================================
local CharacterControllerMod = GetModule("CharacterController")

if CharacterControllerMod then
    local CharController = require(CharacterControllerMod)
    
    -- Sao lưu hàm Update gốc
    if not getgenv().SpeedHack.OriginalUpdate then
        getgenv().SpeedHack.OriginalUpdate = CharController.Update
    end
    
    -- Ghi đè (Hook) hàm Update để can thiệp vào vật lý mỗi frame
    CharController.Update = function(self, dt, ...)
        -- Chạy logic gốc để game không bị lỗi animation
        local result = getgenv().SpeedHack.OriginalUpdate(self, dt, ...)
        
        -- Nếu bật Hack và đang di chuyển
        if getgenv().SpeedHack.Enabled and LocalPlayer.Character then
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            
            if hrp and hum and hum.MoveDirection.Magnitude > 0 then
                -- Ép vị trí (CFrame Injection) ngay trong lúc game đang tính toán vận tốc
                -- Đây là cách bypass ma sát của BRM5 hiệu quả nhất
                local multiplier = (getgenv().SpeedHack.Value / 16) -- Tính tỉ lệ so với tốc độ gốc
                local moveOffset = hum.MoveDirection * ((getgenv().SpeedHack.Value - 16) * dt)
                
                hrp.CFrame = hrp.CFrame + moveOffset
            end
        end
        
        return result
    end
    print("Đã Hook thành công CharacterController!")
else
    warn("LỖI: Không tìm thấy hệ thống điều khiển nhân vật của BRM5.")
end
