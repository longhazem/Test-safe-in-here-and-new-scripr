-- 2. LOGIC ĐIỀU KHIỂN
-- ==========================================
ToggleBtn.MouseButton1Click:Connect(function()
    getgenv().SpeedSettings.Enabled = not getgenv().SpeedSettings.Enabled
    if getgenv().SpeedSettings.Enabled then
        ToggleBtn.Text = "TRẠNG THÁI: BẬT"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
    else
        ToggleBtn.Text = "TRẠNG THÁI: TẮT"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    end
end)

InputBox.FocusLost:Connect(function()
    local val = tonumber(InputBox.Text)
    if val then
        getgenv().SpeedSettings.Multiplier = val
    else
        InputBox.Text = tostring(getgenv().SpeedSettings.Multiplier)
    end
end)

-- ==========================================
-- 3. VÒNG LẶP SPEED BYPASS (CƠ CHẾ CHÍNH)
-- ==========================================
RunService.Stepped:Connect(function(dt)
    if not getgenv().SpeedSettings.Enabled then return end
    
    local Character = LocalPlayer.Character
    local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
    local Humanoid = Character and Character:FindFirstChild("Humanoid")
    
    -- Kiểm tra nếu nhân vật đang di chuyển (MoveDirection > 0)
    if RootPart and Humanoid and Humanoid.MoveDirection.Magnitude > 0 then
        -- Công thức: Vị trí hiện tại + (Hướng đi * (Sức mạnh x DeltaTime))
        -- Điều này cộng dồn vào chuyển động gốc của game mà không bị Anti-cheat phát hiện là 'dịch chuyển'
        local speedMultiplier = (getgenv().SpeedSettings.Multiplier - 1) * 16
        local moveDelta = Humanoid.MoveDirection * (speedMultiplier * dt)
        
        RootPart.CFrame = RootPart.CFrame + moveDelta
    end
end)

