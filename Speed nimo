--[[
    BRM5 ABSOLUTE SPEED BYPASS
    Cơ chế: Hooking nội hàm CharacterController (Bypass Friction & Acceleration)
    Hỗ trợ: PC & Mobile
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- Cấu hình toàn cục
getgenv().SpeedHack = {
    Enabled = false,
    Value = 60, -- Tốc độ mong muốn (Mặc định game là ~16-22)
    OriginalUpdate = nil
}

-- Hàm tìm Module (Đặc thù cho BRM5)
local function GetModule(name)
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("ModuleScript") and v.Name == name then
            return v
        end
    end
    return nil
end

-- ==========================================
-- 1. TẠO GIAO DIỆN (UI) KÉO THẢ
-- ==========================================
