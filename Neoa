function Config:save()
    if writefile then
        local data = {
            wallEnabled = self.wallEnabled,
            outlineEnabled = self.outlineEnabled,
            sizingEnabled = self.sizingEnabled,
            showHitbox = self.showHitbox,
            fullBrightEnabled = self.fullBrightEnabled,
            alwaysDayEnabled = self.alwaysDayEnabled,
            fastScanEnabled = self.fastScanEnabled,
            nvgEnabled = self.nvgEnabled,
            noFogEnabled = self.noFogEnabled,
            patchOptions = self.patchOptions,
            hitboxSize = self.TARGET_BOX_SIZE.X
        }
        pcall(function() writefile(self.CONFIG_FILE, HttpService:JSONEncode(data)) end)
    end
end

function Config:load()
    if isfile and isfile(self.CONFIG_FILE) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(self.CONFIG_FILE)) end)
        if ok then
            self.wallEnabled = data.wallEnabled or false
            self.outlineEnabled = data.outlineEnabled or false
            self.sizingEnabled = data.sizingEnabled or false
            self.showHitbox = data.showHitbox or false
            self.fullBrightEnabled = data.fullBrightEnabled or false
            self.alwaysDayEnabled = data.alwaysDayEnabled or false
            self.fastScanEnabled = data.fastScanEnabled or false
            self.nvgEnabled = data.nvgEnabled or false
            self.noFogEnabled = data.noFogEnabled or false
            if data.patchOptions then self.patchOptions = data.patchOptions end
            if data.hitboxSize then self.TARGET_BOX_SIZE = Vector3.new(data.hitboxSize, data.hitboxSize, data.hitboxSize) end
        end
    end
end

-- ==========================================
-- === 2. TARGET SIZING MODULE (HITBOX) ===
-- ==========================================
local TargetSizing = { originalSizes = {} }

function TargetSizing:apply(model, root)
    if not self.originalSizes[model] then self.originalSizes[model] = root.Size end
    root.Size = Config.TARGET_BOX_SIZE
    root.Transparency = Config.showHitbox and 0.8 or 1
    root.Color = Config.showHitbox and Config.hitboxVisualColor or root.Color
    root.Material = Config.showHitbox and Enum.Material.Neon or root.Material
    root.CanCollide = true
end

function TargetSizing:restore(model, root)
    if root and self.originalSizes[model] then
        root.Size = self.originalSizes[model]
        root.Transparency = 1
        root.CanCollide = false
    end
    self.originalSizes[model] = nil
end

