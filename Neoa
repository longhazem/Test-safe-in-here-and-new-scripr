RunService.RenderStepped:Connect(function()
    if fovCircle then fovCircle.Visible = (Config.silentAimEnabled) fovCircle.Position = camera.ViewportSize / 2 fovCircle.Radius = 180 end
    if Config.fullBrightEnabled then lighting.Brightness = 2 lighting.Ambient = Color3.new(1,1,1) lighting.OutdoorAmbient = Color3.new(1,1,1) end
    if Config.alwaysDayEnabled then lighting.ClockTime = 12 end

    -- ESP Sphere Logic (Check Line of Sight)
    if Config.wallEnabled and localPlayer.Character then
        local origin = camera.CFrame.Position
        for model, data in pairs(activeNPCs) do
            if data.head then
                local sphere = Markers.ensureSphere(data.head, Config.visibleColor)
                local rp = RaycastParams.new()
                rp.FilterDescendantsInstances = {localPlayer.Character, model}
                local res = Workspace:Raycast(origin, data.head.Position - origin, rp)
                sphere.Color3 = (not res) and Config.visibleColor or Config.hiddenColor
            end
        end
    end
end)

task.spawn(function()
    while not Config.isUnloaded do
        if Config.fastScanEnabled then
            for _, m in ipairs(Workspace:GetChildren()) do
                if m.Name == "Model" then
                    for _, npc in ipairs(m:GetChildren()) do
                        if npc:IsA("Model") and isValidNPC(npc) and not activeNPCs[npc] then
                            local head = npc:FindFirstChild("Head")
                            local root = getRoot(npc)
                            if root then activeNPCs[npc] = { head = head or root, root = root } end
                        end
                    end
                end
            end
        end

        -- Outline & Sizing logic
        for model, data in pairs(activeNPCs) do
            if not model.Parent then activeNPCs[model] = nil continue end
            
            -- Outline
            local highlight = model:FindFirstChild("ESP_Outline")
            if Config.outlineEnabled then
                if not highlight then highlight = Instance.new("Highlight", model) highlight.Name = "ESP_Outline" end
                highlight.FillTransparency = 1
                highlight.OutlineColor = string.find(model.Name:lower(), "zombie") and Config.hiddenColor or Config.visibleColor
            elseif highlight then highlight:Destroy() end

            -- Target Sizing
            if Config.sizingEnabled and data.root then
                TargetSizing:apply(model, data.root)
            else
                TargetSizing:restore(model, data.root)
            end
        end
        task.wait(Config.NPC_REFRESH_INTERVAL)
    end
end)

