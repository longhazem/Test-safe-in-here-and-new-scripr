local Players = game:GetService('Players')
local Workspace = game:GetService('Workspace')
local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- Cấu hình Silent Aim
local silentAimFOV = 180
local silentAimPart = "Head" 

-- Danh sách các từ khóa tên Bot/NPC cần quét
local botNames = {"MALE", "male", "MALES", "males", "BOT", "bot", "BOTS", "AI", "AIS"}

-- Khởi tạo vị trí tâm màn hình
local CenterPosition = Camera.ViewportSize / 2

-- Quản lý vòng FOV
local Drawings = {
    FovOutline = nil,
    FovInline = nil
}

-- Các hàm Hook từ Game
local Functions = {
    GetMuzzleCFrame = filtergc('function', {Name = 'GetMuzzleCFrame'}, true),
    GetRecoil = filtergc('function', {Name = 'getRecoil'}, true)
}

-- Hàm tạo đối tượng Drawing
function AddDrawing(Type, Properties)
    local DrawingObject = Drawing.new(Type)
    for Property, Value in pairs(Properties) do
        DrawingObject[Property] = Value
    end
    return DrawingObject
end

-- Hàm kiểm tra xem một Model có phải là Bot dựa trên tên không
local function isBot(model)
    if not model:IsA("Model") then return false end
    local name = model.Name
    for _, keyword in ipairs(botNames) do
        if name:find(keyword) then
            return true
        end
    end
    return false
end

-- Hàm tìm Bot/NPC gần tâm màn hình nhất
function GetClosestBot()
    local bestTargetPart = nil
    local bestDist = silentAimFOV

    -- Quét toàn bộ Workspace để tìm NPC/Bot
    for _, obj in ipairs(Workspace:GetChildren()) do
        if isBot(obj) then
            -- Kiểm tra Humanoid và máu
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                -- Tìm bộ phận bắn (Ưu tiên Head)
                local part = obj:FindFirstChild(silentAimPart) 
                          or obj:FindFirstChild("Head") 
                          or obj:FindFirstChildWhichIsA("BasePart")
                
                if part then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    
                    if onScreen then
                        local mouseDist = (Vector2.new(screenPos.X, screenPos.Y) - CenterPosition).Magnitude
                        
                        if mouseDist < bestDist then
                            bestDist = mouseDist
                            bestTargetPart = part
                        end
                    end
                end
            end
        end
    end
    
    return bestTargetPart
end

-- Khởi tạo hiển thị vòng FOV
Drawings.FovOutline = AddDrawing('Circle', {
    Visible = true, 
    Position = CenterPosition, 
    Radius = silentAimFOV, 
    Thickness = 2, 
    Color = Color3.new(0, 0, 0), 
    Transparency = 0.1
})

Drawings.FovInline = AddDrawing('Circle', {
    Visible = true, 
    Position = CenterPosition, 
    Radius = silentAimFOV, 
    Thickness = 1, 
    Color = Color3.new(1, 0, 0), -- Màu đỏ cho NPC mục tiêu
    Transparency = 0.1
})

-- Hook logic hướng nòng súng (Silent Aim)
local OldMuzzle; OldMuzzle = hookfunction(Functions.GetMuzzleCFrame, function(Self, Cast)
    local Origin, Barrel, CamCF = OldMuzzle(Self, Cast)

    if not Cast and Origin then
        local TargetBotPart = GetClosestBot()
        
        if TargetBotPart then
            -- Bẻ hướng đạn thẳng tới Head của NPC
            local NewOrigin = CFrame.new(Origin.Position, TargetBotPart.Position)
            return NewOrigin, Barrel, CamCF
        end
    end

    return Origin, Barrel, CamCF
end)

-- Hook loại bỏ độ giật
local OldRecoil; OldRecoil = hookfunction(Functions.GetRecoil, function(...)
    local Args = {...}
    if Args[1] and typeof(Args[1]) == "table" then
        Args[1]['Barrel_Spread'] = 0
        Args[1]['RecoilForce_Tap'] = 0
    end
    return OldRecoil(unpack(Args))
end)

-- Cập nhật tâm màn hình
Camera:GetPropertyChangedSignal('ViewportSize'):Connect(function()
    CenterPosition = Camera.ViewportSize / 2
    Drawings.FovOutline.Position = CenterPosition
    Drawings.FovInline.Position = CenterPosition
end)
