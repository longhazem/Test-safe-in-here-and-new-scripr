local zombieColor = Color3.fromRGB(255, 0, 0)

local ModifiedParts = {}
local OriginalSizes = {}

local successHook, mt = pcall(function() return getrawmetatable(game) end)
if successHook and mt then
    local old_index = mt.__index
    setreadonly(mt, false)
    mt.__index = newcclosure(function(t, k)
        if k == "Size" and ModifiedParts[t] then
            return OriginalSizes[t] or Vector3.new(1, 1, 1)
        end
        return old_index(t, k)
    end)
    setreadonly(mt, true)
end

local function UpdateHitboxes()
    if not silentEnabled then
        for part, _ in pairs(ModifiedParts) do
            if part and part.Parent then
                part.Size = OriginalSizes[part]
                part.Transparency = 1
                part.CanCollide = false
            end
            ModifiedParts[part] = nil
        end
        return
    end

    local sizeVal = math.clamp(hitboxSize or 4, 0, 15)
    local expansion = Vector3.new(sizeVal, sizeVal, sizeVal)
    local camPos = camera.CFrame.Position

    local function expand(head)
        if not head or not head:IsA("BasePart") then return end
        local offset = head.Position - camPos
        local distSqr = offset:Dot(offset)
        if distSqr < 25 then return end 
        if distSqr > 1000000 then 
            if ModifiedParts[head] then
                head.Size = OriginalSizes[head]
                head.Transparency = 1
                head.CanCollide = false
                ModifiedParts[head] = nil
            end
            return 
        end
        if not ModifiedParts[head] then
            ModifiedParts[head] = true
            OriginalSizes[head] = head.Size
        end
        if head.Size ~= expansion then head.Size = expansion end
        head.CanCollide = true 
        head.Transparency = showHitbox and 0.4 or 1
    end

    for model, data in pairs(activeNPCs) do
        if model.Parent then
            expand(data.head)
        else
            ModifiedParts[data.head] = nil
        end
    end
end

task.spawn(function()
    while not isUnloaded do
        pcall(UpdateHitboxes)
        task.wait(1)
    end
end)

local originalLighting = {
