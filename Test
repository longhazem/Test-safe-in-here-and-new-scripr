-- Cập nhật ESP & Cleanup
task.spawn(function()
    while not isUnloaded do
        for model, data in pairs(activeNPCs) do
            if not model.Parent or not isValidNPC(model) then
                local h = model:FindFirstChild("ESP_Outline") if h then h:Destroy() end
                local s = data.head:FindFirstChild("Wall_Box") if s then s:Destroy() end
                activeNPCs[model] = nil
            else
                if outlineEnabled then applyOutline(model) end
            end
        end
        task.wait(0.5)
    end
end)

-- HITBOX LOOP
task.spawn(function()
    while not isUnloaded do
        if silentEnabled then
            for model, data in pairs(activeNPCs) do
                if model.Parent and data.root then applySilentHitbox(model, data.root) end
            end
        else
            for model, _ in pairs(originalSizes) do restoreOriginalSize(model) end
        end
        task.wait(0.1)
    end
end)

-- SCAN LOOP
task.spawn(function()
    while not isUnloaded do
        if fastScanEnabled then
            local items = Workspace:GetDescendants()
            for i, m in ipairs(items) do
                if not fastScanEnabled or isUnloaded then break end
                if m:IsA("Model") and not activeNPCs[m] and isValidNPC(m) then
                    addNPC(m)
                end
                if i % 300 == 0 then task.wait() end 
            end
        end
        task.wait(0.001)
    end
end)

RunService.RenderStepped:Connect(function()
    if isUnloaded then return end
    if fullBrightEnabled then
        lighting.Brightness = 2
        lighting.Ambient = Color3.new(1, 1, 1)
    end
    if alwaysDayEnabled then lighting.ClockTime = 12 end
end)

-- Khởi tạo
for _, m in ipairs(Workspace:GetDescendants()) do
