getgenv().CharSettings = {
    FlyEnabled = false,
    FlySpeed = 55
}

local user_input_service = game:GetService("UserInputService")
local workspace = game:GetService("Workspace")
local Vector3_new = Vector3.new
local CFrame_new = CFrame.new

local function findModule(name)
    for _, v in ipairs(game:GetService("ReplicatedFirst"):GetDescendants()) do
        if v:IsA("ModuleScript") and v.Name == name then return v end
    end
    for _, v in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
        if v:IsA("ModuleScript") and v.Name == name then return v end
    end
    return nil
end

task.spawn(function()
    local CharacterController = nil
    while not CharacterController do
        local mod = findModule("CharacterController")
        if mod then
            local success, result = pcall(require, mod)
            if success and result and result.Update then
                CharacterController = result
                print("BRM5: Đã tìm đúng Controller của bạn!")

                if not getgenv().OldCharUpdate then
                    getgenv().OldCharUpdate = CharacterController.Update
                end

                CharacterController.Update = function(self, inputVector, deltaTime)
                    -- Kiểm tra xem đây có phải là LocalPlayer không (Bypass NPC)
                    if not self or not self._localActor then 
                        return getgenv().OldCharUpdate(self, inputVector, deltaTime) 
                    end

                    if getgenv().CharSettings.FlyEnabled then
                        -- Tắt trọng lực nội bộ của Flux
                        self.VelocityGravity = 0
                        self.HeightState = 0 
                        self.IsGrounded = true
                        
                        local camCF = workspace.CurrentCamera.CFrame
                        local moveDir = Vector3_new(0, 0, 0)

                        -- Tính hướng di chuyển
                        if inputVector.Magnitude > 0 then
                            moveDir = moveDir + (camCF.LookVector * -inputVector.Y) + (camCF.RightVector * inputVector.X)
                        end
                        if user_input_service:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3_new(0, 1, 0) end
                        if user_input_service:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3_new(0, 1, 0) end

                        -- Cập nhật vị trí logic
                        if moveDir.Magnitude > 0 then
                            local speed = getgenv().CharSettings.FlySpeed
                            local sprint = user_input_service:IsKeyDown(Enum.KeyCode.LeftShift) and 2.5 or 1
                            self._position = self._position + (moveDir.Unit * speed * sprint * deltaTime)
                        end

                        -- CẬP NHẬT VẬT LÝ (Quan trọng để bay thực sự)
                        -- _localActor._model là nơi chứa nhân vật thực trong BRM5
                        local model = self._localActor._model
                        if model then
                            -- Sử dụng PrimaryPart để di chuyển cả khối nhân vật
                            local root = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
                            if root then
                                root.CFrame = CFrame_new(self._position, self._position + camCF.LookVector)
                                -- Đóng băng vận tốc để không bị rơi do trọng lực Roblox
                                root.AssemblyLinearVelocity = Vector3_new(0, 0, 0)
                            end
                        end

                        -- Đồng bộ hóa lại cho hệ thống Anti-cheat của game
                        self._lastSafePosition = self._position
                        self._localActor.SimulatedPosition = self._position
                        
                        -- Chạy hàm gốc với input trống để giữ animation (cầm súng, thở...)
                        return getgenv().OldCharUpdate(self, Vector3_new(0,0,0), deltaTime)
                    end

                    return getgenv().OldCharUpdate(self, inputVector, deltaTime)
                end
                break
            end
        end
        task.wait(1)
    end
end)

-- Phím tắt (T)
user_input_service.InputBegan:Connect(function(input, typing)
    if typing then return end
    if input.KeyCode == Enum.KeyCode.T then
        getgenv().CharSettings.FlyEnabled = not getgenv().CharSettings.FlyEnabled
        print("Fly đang: " .. (getgenv().CharSettings.FlyEnabled and "BẬT" or "TẮT"))
    end
end)
