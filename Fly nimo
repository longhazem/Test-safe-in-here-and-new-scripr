-- Cấu hình
getgenv().CharSettings = {
    FlyEnabled = false,
    FlySpeed = 50,
    VerticalSpeed = 40
}

local run_service = game:GetService("RunService")
local user_input_service = game:GetService("UserInputService")
local workspace = game:GetService("Workspace")

-- Hàm tìm Part chính của nhân vật (Dựa trên ảnh Dex bạn gửi là 'Male')
local function getRoot()
    local char = game.Players.LocalPlayer.Character
    if not char then return nil end
    -- BRM5 dùng Model 'Male', chúng ta tìm Part nằm trong đó
    return char:FindFirstChild("Male") or char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
end

-- Vòng lặp ÉP VỊ TRÍ (Đây là phần quan trọng nhất)
run_service.Stepped:Connect(function(_, deltaTime)
    if not getgenv().CharSettings.FlyEnabled then return end
    
    local root = getRoot()
    if not root then return end
    
    local camCF = workspace.CurrentCamera.CFrame
    local moveDir = Vector3.new(0, 0, 0)
    
    -- Tính toán hướng di chuyển từ phím bấm
    if user_input_service:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
    if user_input_service:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
    if user_input_service:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
    if user_input_service:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
    
    -- Bay lên/xuống (Space/Ctrl)
    if user_input_service:IsKeyDown(Enum.KeyCode.Space) then 
        moveDir = moveDir + Vector3.new(0, 1, 0) 
    end
    if user_input_service:IsKeyDown(Enum.KeyCode.LeftControl) then 
        moveDir = moveDir - Vector3.new(0, 1, 0) 
    end

    if moveDir.Magnitude > 0 then
        local multiplier = user_input_service:IsKeyDown(Enum.KeyCode.LeftShift) and 2 or 1
        local nextPos = root.Position + (moveDir.Unit * getgenv().CharSettings.FlySpeed * multiplier * deltaTime)
        
        -- ÉP CFrame liên tục để bypass trọng lực của game
        root.CFrame = CFrame.new(nextPos, nextPos + camCF.LookVector)
    end
    
    -- KHÓA VẬN TỐC: Quan trọng để không bị game kéo xuống đất
    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
end)

-- Phím tắt bật/tắt (T)
user_input_service.InputBegan:Connect(function(input, typing)
    if typing then return end
    if input.KeyCode == Enum.KeyCode.T then
        getgenv().CharSettings.FlyEnabled = not getgenv().CharSettings.FlyEnabled
        print("Fly BRM5: " .. (getgenv().CharSettings.FlyEnabled and "BẬT" or "TẮT"))
        
        -- Khi bật Fly, nhấc nhân vật lên một chút để thoát khỏi mặt đất
        if getgenv().CharSettings.FlyEnabled then
            local root = getRoot()
            if root then root.CFrame = root.CFrame + Vector3.new(0, 5, 0) end
        end
    end
end)
