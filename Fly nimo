-- BRM5 Fly Fix
getgenv().CharSettings = {
    FlyEnabled = false,
    FlySpeed = 60 -- BRM5 map rộng nên để tầm 60-80 cho nhanh
}

local settings = getgenv().CharSettings
local uis = game:GetService("UserInputService")
local runService = game:GetService("RunService")
local players = game:GetService("Players")
local lp = players.LocalPlayer

-- Hàm tìm kiếm module sâu hơn cho BRM5
local function getBRM5Controller()
    for _, v in ipairs(getgc(true)) do
        if type(v) == "table" and rawget(v, "Update") and rawget(v, "_localActor") then
            return v
        end
    end
    return nil
end

local controller = getBRM5Controller()

-- Vòng lặp chính để xử lý bay (Thay vì Hook hàm Update của game)
runService.Heartbeat:Connect(function(dt)
    if not settings.FlyEnabled then return end
    
    local char = lp.Character
    if not char then return end
    local root = char:FindFirstChild("Root") or char.PrimaryPart
    if not root then return end

    -- Vô hiệu hóa trọng lực của BRM5 bằng cách ép Velocity
    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    
    local camCF = workspace.CurrentCamera.CFrame
    local moveDir = Vector3.new(0, 0, 0)

    -- Phím di chuyển cơ bản
    if uis:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camCF.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camCF.LookVector end
    if uis:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camCF.RightVector end
    if uis:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camCF.RightVector end
    
    -- Bay lên/xuống
    if uis:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, 1, 0) end
    if uis:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, 1, 0) end

    if moveDir.Magnitude > 0 then
        local speed = settings.FlySpeed
        if uis:IsKeyDown(Enum.KeyCode.LeftShift) then speed = speed * 2 end
        
        -- Ép CFrame để bay (Đây là cách duy nhất qua mặt được controller của BRM5)
        root.CFrame = root.CFrame + (moveDir.Unit * speed * dt)
    end
    
    -- Cập nhật cho Controller của game để không bị giật ngược (Anti-Teleport nhẹ)
    if controller then
        controller._position = root.Position
        if controller._localActor then
            controller._localActor.SimulatedPosition = root.Position
        end
    end
end)

-- Bật/Tắt
uis.InputBegan:Connect(function(input, typing)
    if typing then return end
    if input.KeyCode == Enum.KeyCode.T then
        settings.FlyEnabled = not settings.FlyEnabled
        print("BRM5 Fly:", settings.FlyEnabled)
        
        -- Reset vận tốc khi tắt để không bị rớt cái rầm
        if not settings.FlyEnabled and lp.Character then
            local root = lp.Character:FindFirstChild("Root") or lp.Character.PrimaryPart
            if root then root.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
        end
    end
end)

warn(">>> BRM5 FLY LOADED - PRESS T TO TOGGLE 🗿")
