local function get_actor_from_player(p)
    if not p then return nil end
    local id, now = p.UserId, tick()
    local ent = player_actor_cache[id]
    if ent and (now - ent.t) < 0.5 then return ent.v end
    
    local actor = nil
    if replicator_service then
        local ok, res = pcall(function() return replicator_service:GetFromPlayer(p) end)
        if ok then actor = res end
    end
    if not actor and p.Character then
        local tp = players:GetPlayerFromCharacter(p.Character)
        if tp and tp ~= p then actor = get_actor_from_player(tp) end
        if not actor and type(getgenv().actor_list) == "table" then
            for a in pairs(getgenv().actor_list) do
                if a.Character == p.Character then actor = a break end
            end
        end
    end
    player_actor_cache[id] = { v = actor, t = now }
    return actor
end

