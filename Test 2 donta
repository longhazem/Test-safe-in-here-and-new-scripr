local function render_esp(id, actor, color, is_visible_toggle)
    if not is_visible_toggle then if esp_objects[id] then esp_objects[id].Visible = false end return end
    local root = actor.Character and (actor.Character:FindFirstChild("Head") or actor.Character.PrimaryPart)
    if not root or not is_alive(actor) then if esp_objects[id] then esp_objects[id].Visible = false end return end

    if not esp_objects[id] then
        local box = Instance.new("BoxHandleAdornment")
        box.AlwaysOnTop = true
        box.ZIndex = 5
        box.Transparency = 0
        box.Parent = GetESPFolder()
        esp_objects[id] = box
    end
    
    local box = esp_objects[id]
    box.Visible = true
    box.Adornee = root
    box.Size = root.Size * 1.2
    box.Color3 = color
end

add_connection(run_service.RenderStepped:Connect(function()
    update_camera()
    local camPos = camera.CFrame.Position
    local my_team = get_team(local_player)
    
    local sa_bestPart = nil
    local sa_minFOVDist = math.huge
    local sa_maxFOVSqr = (Config.FOVRadius or 400)^2
    local sa_screenCenter = camera.ViewportSize / 2

    for _, p in ipairs(players:GetPlayers()) do
        if p == local_player then continue end
        local actor = get_actor_from_player(p)
        if not actor or not actor.Character then continue end
        
        local root = actor.Character.PrimaryPart
        if root then
            local is_team = (get_team(p) == my_team)
            local color = is_team and Config.TeamColor or Config.EnemyColor
            local visible = Config.ESPEnabled and (is_team and Config.ShowTeammates or Config.ShowPlayers)
            render_esp(p.UserId, actor, color, visible)

            if Config.SilentAimEnabled and is_alive(actor) and (not Config.TeamCheck or not is_team) then
                local part = actor.Character:FindFirstChild(Config.TargetPart) or root
                local pos, onScreen = camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local fovDist = (Vector2.new(pos.X, pos.Y) - sa_screenCenter).Magnitude ^ 2
                    if fovDist < sa_maxFOVSqr and fovDist < sa_minFOVDist and is_visible(part) then
                        sa_minFOVDist = fovDist
                        sa_bestPart = part
                    end
                end
            end
        end
    end
    CurrentSilentAimTarget = sa_bestPart
end))


