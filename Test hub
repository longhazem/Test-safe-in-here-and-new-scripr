-- Loop cập nhật Hitbox & ESP
task.spawn(function()
    while not Settings.IsUnloaded do
        for model, data in pairs(ActiveNPCs) do
            if not model.Parent or not IsValidNPC(model) then
                ActiveNPCs[model] = nil
            else
                ApplyESP(model)
                local head = data.head
                if head then
                    if Settings.SilentEnabled then
                        if not OriginalSizes[head] then OriginalSizes[head] = head.Size end
                        ModifiedParts[head] = true
                        head.Size = Vector3.new(Settings.HitboxSize, Settings.HitboxSize, Settings.HitboxSize)
                        head.Transparency = Settings.ShowHitbox and 0.7 or head.Transparency
                        head.CanCollide = false
                    else
                        if OriginalSizes[head] then
                            head.Size = OriginalSizes[head]
                            head.Transparency = 0
                            head.CanCollide = true
                            ModifiedParts[head] = nil
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

-- Loop quét NPC mới
task.spawn(function()
    while not Settings.IsUnloaded do
        if Settings.FastScan then
            for _, m in ipairs(Workspace:GetDescendants()) do
                if m:IsA("Model") and not ActiveNPCs[m] and IsValidNPC(m) then
                    local head = m:FindFirstChild("Head") or m:FindFirstChild("UpperTorso")
                    if head then ActiveNPCs[m] = { head = head } end
                end
            end
        end
        task.wait(5)
    end
end)

-- Loop Render Lighting
RunService.Heartbeat:Connect(function()
    if Settings.IsUnloaded then return end
    if Settings.FullBright then
        Lighting.Brightness = 2
        Lighting.Ambient = Color3.new(1, 1, 1)
        Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
    end
    if Settings.AlwaysDay then Lighting.ClockTime = 12 end
end)

