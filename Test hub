------------------------------------------------------------------
-- [[ METATABLE HOOK - HITBOX SPOOFER ]]
------------------------------------------------------------------
-- Giúp phóng to hitbox mà game vẫn tưởng là size cũ (Tránh Anti-cheat)
local success, mt = pcall(getrawmetatable, game)
if success and mt then
    local old_index = mt.__index
    local set_readonly = setreadonly or make_writeable or function(t, b) end
    set_readonly(mt, false)
    mt.__index = newcclosure(function(t, k)
        if not Settings.IsUnloaded and k == "Size" and ModifiedParts[t] then
            return OriginalSizes[t] or Vector3.new(1, 1, 1)
        end
        return old_index(t, k)
    end)
    set_readonly(mt, true)
end

------------------------------------------------------------------
-- [[ CHỨC NĂNG VŨ KHÍ ]]
------------------------------------------------------------------
local function PatchWeapons()
    pcall(function()
        local WeaponFolder = RS:FindFirstChild("Shared") and RS.Shared:FindFirstChild("Configs") and RS.Shared.Configs:FindFirstChild("Weapon") and RS.Shared.Configs.Weapon:FindFirstChild("Weapons_Player")
        if not WeaponFolder then return end

        for _, platform in pairs(WeaponFolder:GetChildren()) do
            for _, weapon in pairs(platform:GetChildren()) do
                for _, child in pairs(weapon:GetChildren()) do
                    if child:IsA("ModuleScript") and child.Name:find("Receiver") then
                        task.spawn(function()
                            local successReq, receiver = pcall(require, child)
                            if successReq and receiver and receiver.Config and receiver.Config.Tune then
                                local tune = receiver.Config.Tune
                                if Settings.NoRecoil then
                                    tune.Recoil_X = 0 tune.Recoil_Z = 0 tune.Recoil_Camera = 0
                                    tune.RecoilForce_Tap = 0 tune.RecoilForce_Impulse = 0
                                end
                                if Settings.UnlockFiremodes then
                                    tune.Firemodes = {3, 2, 1, 0}
                                end
                            end
                        end)
                    end
                end
            end
        end
    end)
end

------------------------------------------------------------------
-- [[ LOGIC NPC & ESP ]]
------------------------------------------------------------------
local function IsValidNPC(model)
    if not model or not model.Parent then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return false end
    
    local name = model.Name:lower()
    if name == "male" or name:find("zombie") then
        -- Kiểm tra thêm tag AI của BRM5
        for _, c in ipairs(model:GetChildren()) do
            if c.Name:sub(1, 3) == "AI_" then return true end
        end
        if name:find("zombie") then return true end
    end
    return false
end

local function ApplyESP(model)
    if not model or not model.Parent then return end
    
    -- 1. Outline ESP
    local highlight = model:FindFirstChild("Tokai_Outline")
    if Settings.OutlineEnabled then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "Tokai_Outline"
            highlight.Parent = model
        end
        highlight.FillTransparency = 1
        highlight.OutlineColor = model.Name:lower():find("zombie") and ZombieColor or MaleColor
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    elseif highlight then
        highlight:Destroy()
    end

    -- 2. Sphere ESP (Wall Box)
    local head = model:FindFirstChild("Head")
    if head and Settings.WallEnabled then
        if not head:FindFirstChild("Tokai_Sphere") then
            local sphere = Instance.new("SphereHandleAdornment")
            sphere.Name = "Tokai_Sphere"
            sphere.Radius = 1.3
            sphere.Adornee = head
            sphere.AlwaysOnTop = true
            sphere.ZIndex = 10
            sphere.Transparency = 0.4
            sphere.Color3 = model.Name:lower():find("zombie") and ZombieColor or MaleColor
            sphere.Parent = head
            TrackedBoxes[head] = sphere
        end
    end
end

