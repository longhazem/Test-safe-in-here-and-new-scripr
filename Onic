    tabLayout.Padding = UDim.new(0, 6)

    -- HÀM TẠO VIỀN NEON CHO TAG (Đúng yêu cầu ảnh bạn gửi)
    local function ApplyNeonTag(target)
        if target:FindFirstChild("NeonGlow") then target.NeonGlow:Destroy() end
        
        local glow = Instance.new("ImageLabel", target)
        glow.Name = "NeonGlow"
        glow.BackgroundTransparency = 1
        glow.Image = "rbxassetid://1316045217" -- Asset cho hiệu ứng hào quang
        glow.ImageColor3 = NEON_COLOR
        glow.ScaleType = Enum.ScaleType.Slice
        glow.SliceCenter = Rect.new(10, 10, 118, 118)
        glow.AnchorPoint = Vector2.new(0.5, 0.5)
        glow.Position = UDim2.new(0.5, 0, 0.5, 0)
        glow.Size = UDim2.new(1, 15, 1, 15) -- Lớn hơn nút một chút
        glow.ZIndex = target.ZIndex - 1
        
        -- Hiệu ứng Neon thở
        task.spawn(function()
            while glow and glow.Parent do
                TweenService:Create(glow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {ImageTransparency = 0.2}):Play()
                task.wait(1.2)
                TweenService:Create(glow, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {ImageTransparency = 0.7}):Play()
                task.wait(1.2)
            end
        end)
    end

    local firstTab = true
    function Library:CreateTab(name)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name .. "Page"
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.Visible = false
        page.ScrollBarThickness = 2
