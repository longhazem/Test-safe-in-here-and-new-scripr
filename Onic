    tabListScroll.Position = UDim2.new(0, 0, 0, 65)
    tabListScroll.BackgroundTransparency = 1
    tabListScroll.BorderSizePixel = 0
    tabListScroll.ScrollBarThickness = 0
    tabListScroll.ZIndex = 11
