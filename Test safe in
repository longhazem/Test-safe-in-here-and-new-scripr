------------------------------------------------------------------
-- [[ LOGIC HỖ TRỢ: HITBOX & UTILS ]]
------------------------------------------------------------------
local ModifiedParts = {}
local OriginalSizes = {}

-- Metatable Hooking (Spoofing Size)
local mt = getrawmetatable(game)
local old_index = mt.__index
setreadonly(mt, false)
mt.__index = newcclosure(function(t, k)
    if k == "Size" and ModifiedParts[t] then
        return OriginalSizes[t] or Vector3.new(1, 1, 1)
    end
    return old_index(t, k)
end)
setreadonly(mt, true)

local function UpdateHitboxes()
    if not silentEnabled then
        for part, _ in pairs(ModifiedParts) do
            if part and part.Parent then
                part.Size = OriginalSizes[part] or part.Size
                part.Transparency = 1 
                part.CanCollide = false
            end
            ModifiedParts[part] = nil
        end
        return
    end

    local sizeVal = hitboxSize or 4
    local expansion = Vector3.new(sizeVal, sizeVal, sizeVal)
    local camPos = camera.CFrame.Position

    for model, data in pairs(activeNPCs) do
        local head = data.head
        if not model.Parent then
            ModifiedParts[head] = nil
            continue
        end

        if head and head:IsA("BasePart") then
            local offset = head.Position - camPos
            if offset.Magnitude < 5 then continue end 

            if not ModifiedParts[head] then
                ModifiedParts[head] = true
                OriginalSizes[head] = head.Size
            end
            
            head.Size = expansion
            head.CanCollide = true
            head.Transparency = showHitbox and 0.4 or 1
        end
    end
end

local function isValidNPC(model)
    local name = model.Name:lower()
    if name == "male" then
        for _, c in ipairs(model:GetChildren()) do
            if c.Name:sub(1, 3) == "AI_" then return true end
        end
    end
    return (name == "zombie" or name == "zombies" or name == "male")
end

local function createBoxForPart(part)
    if not part or part:FindFirstChild("Wall_Box") then return end
    local sphere = Instance.new("SphereHandleAdornment")
    sphere.Name = "Wall_Box"
    sphere.Radius = 1.2
    sphere.Adornee = part
    sphere.AlwaysOnTop = true 
    sphere.ZIndex = 10
    sphere.Transparency = 0.5
    local model = part.Parent
    sphere.Color3 = (model.Name:lower():find("zombie")) and zombieColor or maleColor
    sphere.Parent = part
    trackedParts[part] = true
end

local function destroyAllBoxes()
    for part, _ in pairs(trackedParts) do
        if part and part:FindFirstChild("Wall_Box") then pcall(function() part.Wall_Box:Destroy() end) end
    end
    trackedParts = {}
end

local function addNPC(model)
    if activeNPCs[model] or not isValidNPC(model) then return end
    local head = model:FindFirstChild("Head") or model:FindFirstChild("Root") or model:FindFirstChild("HumanoidRootPart")
    if head then
        activeNPCs[model] = { head = head }
        if wallEnabled then createBoxForPart(head) end
    end
end

local function patchWeapons()
    local success, weaponsFolder = pcall(function() 
        return RS.Shared.Configs.Weapon.Weapons_Player 
    end)
    if not success then return end

    for _, platform in pairs(weaponsFolder:GetChildren()) do
        for _, weapon in pairs(platform:GetChildren()) do
            for _, child in pairs(weapon:GetChildren()) do
                if child:IsA("ModuleScript") and child.Name:match("^Receiver%.") then
                    local s, receiver = pcall(require, child)
                    if s and receiver.Config and receiver.Config.Tune then
                        local tune = receiver.Config.Tune
                        if patchOptions.recoil then
                            tune.Recoil_X = 0 tune.Recoil_Z = 0 tune.RecoilForce_Tap = 0
                            tune.RecoilForce_Impulse = 0 tune.Recoil_Range = Vector2.zero
                        end
                        if patchOptions.firemodes then tune.Firemodes = {3, 2, 1, 0} end
                    end
                end
            end
        end
    end
end

