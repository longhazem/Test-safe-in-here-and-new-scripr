            local enabled = false
            local function update()
                TweenService:Create(tglDot, TweenInfo.new(0.2), {Position = enabled and UDim2.new(0, 22, 0.5, -9) or UDim2.new(0, 2, 0.5, -9)}):Play()
                TweenService:Create(tglBg, TweenInfo.new(0.2), {BackgroundColor3 = enabled and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(65, 65, 65)}):Play()
            end
            toggleFrame.MouseButton1Click:Connect(function() PlayCustomClick(); enabled = not enabled; update(); callback(enabled) end)
        end

