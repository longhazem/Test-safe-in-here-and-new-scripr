local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false

    -- Cấu hình màu sắc theo ảnh (Hồng Glassmorphism)
    local MainColor = Color3.fromRGB(255, 192, 203) -- Màu hồng chủ đạo
    local DarkPink = Color3.fromRGB(230, 150, 170)
    local TextColor = Color3.fromRGB(100, 50, 60) -- Màu chữ đậm cho dễ đọc trên nền hồng

    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0, 650, 0, 420)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.2
    main.Parent = screenGui
    
    local mainCorner = Instance.new("UICorner", main)
    mainCorner.CornerRadius = UDim.new(0, 30) -- Bo góc cực mạnh như ảnh

    -- Hiệu ứng Glass (Viền trắng mỏng)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.Thickness = 2.5
    mainStroke.Transparency = 0.5

    -- Background Pattern (Lớp phủ mờ)
    local pattern = Instance.new("Frame", main)
    pattern.Size = UDim2.new(1, 0, 1, 0)
    pattern.BackgroundTransparency = 0.8
    pattern.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", pattern).CornerRadius = UDim.new(0, 30)

    -- LEFT SECTION: Profile & Welcome
    local profileFrame = Instance.new("Frame", main)
    profileFrame.Size = UDim2.new(0, 300, 0, 180)
    profileFrame.Position = UDim2.new(0, 25, 0, 25)
    profileFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    profileFrame.BackgroundTransparency = 0.6
    Instance.new("UICorner", profileFrame).CornerRadius = UDim.new(0, 20)

    local pfp = Instance.new("ImageLabel", profileFrame)
    pfp.Size = UDim2.new(0, 100, 0, 100)
    pfp.Position = UDim2.new(0, 15, 0.5, -50)
    pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
    pfp.BackgroundColor3 = MainColor
    Instance.new("UICorner", pfp).CornerRadius = UDim.new(1, 0)

    local welcomeMsg = Instance.new("TextLabel", profileFrame)
    welcomeMsg.Size = UDim2.new(1, -130, 1, 0)
    welcomeMsg.Position = UDim2.new(0, 125, 0, 0)
    welcomeMsg.BackgroundTransparency = 1
    welcomeMsg.Text = "The lanterns light your way~,\n" .. Players.LocalPlayer.DisplayName .. "!\n\nWelcome to Tokai Hub"
    welcomeMsg.TextColor3 = TextColor
    welcomeMsg.Font = Enum.Font.GothamBold
    welcomeMsg.TextSize = 16
    welcomeMsg.TextWrapped = true
    welcomeMsg.TextXAlignment = Enum.TextXAlignment.Left

    -- RIGHT SECTION: About
    local aboutFrame = Instance.new("Frame", main)
    aboutFrame.Size = UDim2.new(0, 250, 0, 180)
    aboutFrame.Position = UDim2.new(1, -275, 0, 25)
    aboutFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    aboutFrame.BackgroundTransparency = 0.6
    Instance.new("UICorner", aboutFrame).CornerRadius = UDim.new(0, 20)

    local aboutText = Instance.new("TextLabel", aboutFrame)
    aboutText.Size = UDim2.new(1, -20, 1, -20)
    aboutText.Position = UDim2.new(0, 10, 0, 10)
    aboutText.BackgroundTransparency = 1
    aboutText.Text = "Tokai Hub is a specialized Roblox development project.\n\nCreated by LONGTOKAI.\nEnjoy the experience!"
    aboutText.TextColor3 = TextColor
    aboutText.Font = Enum.Font.Gotham
    aboutText.TextSize = 13
    aboutText.TextWrapped = true
    aboutText.TextYAlignment = Enum.TextYAlignment.Top

    -- SIDEBAR (Thanh điều hướng bên phải)
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 50, 0, 320)
    sidebar.Position = UDim2.new(1, 60, 0.5, -160)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.5
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(0, 25)
    Instance.new("UIStroke", sidebar).Color = Color3.fromRGB(255, 255, 255)

    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0, 15)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    -- Tab Container
    local tabContainer = Instance.new("Frame", main)
    tabContainer.Size = UDim2.new(1, -50, 0, 160)
    tabContainer.Position = UDim2.new(0, 25, 1, -185)
    tabContainer.BackgroundTransparency = 1

    local pages = Instance.new("Frame", tabContainer)
    pages.Size = UDim2.new(1, 0, 1, 0)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0, 185, 0, 45)
        layout.CellPadding = UDim2.new(0, 10, 0, 10)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0, 35, 0, 35)
        tabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        tabBtn.BackgroundTransparency = 0.8
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.TextColor3 = TextColor
        tabBtn.TextSize = 18
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1, 0)

        tabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
            TweenService:Create(tabBtn, TweenInfo.new(0.3), {BackgroundTransparency = 0.2}):Play()
        end)

        local elements = {}
        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.BackgroundTransparency = 0.4
            btn.Text = text
            btn.Font = Enum.Font.GothamSemibold
            btn.TextColor3 = TextColor
            btn.TextSize = 14
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
            btn.MouseButton1Click:Connect(callback)
        end
        
        -- Mặc định mở tab đầu tiên
        if #sidebar:GetChildren() == 2 then -- 1 layout + 1 btn
            page.Visible = true
            tabBtn.BackgroundTransparency = 0.2
        end

        return elements
    end

    -- Kéo thả (Draggable)
    local dragging, dragStart, startPos
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    return Library
end

-- Cách sử dụng
local win = Library:CreateWindow()
local mainTab = win:CreateTab("Home", "H")
mainTab:AddButton("Test Script 1", function() print("Clicked!") end)
mainTab:AddButton("Destroy UI", function() CleanupOldUI() end)

local settingTab = win:CreateTab("Settings", "S")
settingTab:AddButton("Reset Config", function() end)
