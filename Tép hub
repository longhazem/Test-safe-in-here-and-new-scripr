local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

-- Hàm xử lý âm thanh nối tiếp
local function PlayIntroSounds()
    local s1 = Instance.new("Sound", game:GetService("SoundService"))
    s1.SoundId = "rbxassetid://87585111317596"
    s1.Volume = 1
    
    local s2 = Instance.new("Sound", game:GetService("SoundService"))
    s2.SoundId = "rbxassetid://88375863598461"
    s2.Volume = 1
    s2.Looped = true -- Thường âm thanh thứ 2 sẽ là nhạc nền nên mình để Looped

    s1:Play()
    s1.Ended:Wait() -- Đợi âm thanh 1 xong
    s2:Play()
end

