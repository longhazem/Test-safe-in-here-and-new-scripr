local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local startTime = os.time() -- Lưu thời điểm bắt đầu chạy script

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    local MainColor = Color3.fromRGB(255, 182, 193)
    local TextColor = Color3.fromRGB(90, 45, 55)
    local DarkPink = Color3.fromRGB(235, 110, 140)

    -- MAIN FRAME (364px cho Mobile)
    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0, 364, 0, 240)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.3
    main.Parent = screenGui
    
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 15)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.Thickness = 1.5
    mainStroke.Transparency = 0.6

    -- Thanh Bar dưới cùng
    local bottomBar = Instance.new("Frame", main)
    bottomBar.Size = UDim2.new(0.9, 0, 0, 2)
    bottomBar.Position = UDim2.new(0.05, 0, 0.95, -5)
    bottomBar.BackgroundColor3 = Color3.new(1, 1, 1)
    bottomBar.BackgroundTransparency = 0.6
    Instance.new("UICorner", bottomBar)

    -- SIDEBAR
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 35, 0, 180)
    sidebar.Position = UDim2.new(1, -40, 0.5, -90)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.7
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(1, 0)

    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0, 8)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    local tabContainer = Instance.new("Frame", main)
    tabContainer.Size = UDim2.new(0, 310, 0, 200)
    tabContainer.Position = UDim2.new(0, 10, 0, 15)
    tabContainer.BackgroundTransparency = 1

    local pages = Instance.new("Frame", tabContainer)
    pages.Size = UDim2.new(1, 0, 1, 0)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name .. "Page"
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0.48, 0, 0, 35)
        layout.CellPadding = UDim2.new(0.02, 0, 0.02, 0)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0, 28, 0, 28)
        tabBtn.BackgroundColor3 = DarkPink
        tabBtn.BackgroundTransparency = 0.2
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.TextScaled = true
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1, 0)

        tabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)

        local elements = {}

        function elements:AddDashboard()
            layout:Destroy() 
            
            local function CreateBox(size, pos, titleText)
                local box = Instance.new("Frame", page)
                box.Size = size
                box.Position = pos
                box.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                box.BackgroundTransparency = 0.6
                Instance.new("UICorner", box).CornerRadius = UDim.new(0, 10)
                
                local label = Instance.new("TextLabel", box)
                label.Size = UDim2.new(0, 12, 1, 0)
                label.Position = UDim2.new(1, -15, 0, 0)
                label.Text = titleText or ""
                label.Font = Enum.Font.GothamBold
                label.TextColor3 = DarkPink
                label.TextSize = 7
                label.TextWrapped = true
                label.BackgroundTransparency = 1
                return box
            end

            -- 1. USER BOX
            local userBox = CreateBox(UDim2.new(0.6, 0, 0.47, 0), UDim2.new(0, 0, 0, 0))
            local pfp = Instance.new("ImageLabel", userBox)
            pfp.Size = UDim2.new(0, 55, 0, 55)
            pfp.Position = UDim2.new(0, 5, 0.5, -27)
            pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            pfp.BackgroundTransparency = 1
            Instance.new("UICorner", pfp).CornerRadius = UDim.new(1, 0)

            local greet = Instance.new("TextLabel", userBox)
            greet.Size = UDim2.new(0.5, 0, 0.5, 0)
            greet.Position = UDim2.new(0, 65, 0.2, 0)
            greet.Text = "The lanterns light your way~, \n" .. Players.LocalPlayer.DisplayName
            greet.Font = Enum.Font.GothamBold
            greet.TextColor3 = TextColor
            greet.TextSize = 9
            greet.TextXAlignment = "Left"
            greet.BackgroundTransparency = 1

            -- 2. ABOUT BOX
            local aboutBox = CreateBox(UDim2.new(0.37, 0, 0.47, 0), UDim2.new(0.63, 0, 0, 0), "A\nB\nO\nU\nT")
            local aboutDesc = Instance.new("TextLabel", aboutBox)
            aboutDesc.Size = UDim2.new(0.75, 0, 0.8, 0)
            aboutDesc.Position = UDim2.new(0.05, 0, 0.1, 0)
            aboutDesc.Text = "Yae Miko is the head shrine maiden of the Grand Narukami Shrine."
            aboutDesc.Font = Enum.Font.Gotham
            aboutDesc.TextColor3 = TextColor
            aboutDesc.TextSize = 7
            aboutDesc.TextWrapped = true
            aboutDesc.TextXAlignment = "Left"
            aboutDesc.BackgroundTransparency = 1

            -- 3. MUSIC BOX (Để trống theo yêu cầu)
            local musicBox = CreateBox(UDim2.new(0.35, 0, 0.47, 0), UDim2.new(0, 0, 0.53, 0), "M\nU\nS\nI\nC")

            -- 4. STATUS BOX (Fix Overlap & Uptime)
            local statBox = CreateBox(UDim2.new(0.62, 0, 0.47, 0), UDim2.new(0.38, 0, 0.53, 0), "S\nT\nA\nT\nU\nS")
            
            -- Đồng hồ
            local timeLabel = Instance.new("TextLabel", statBox)
            timeLabel.Size = UDim2.new(0, 80, 0, 25)
            timeLabel.Position = UDim2.new(0, 5, 0, 5)
            timeLabel.Font = Enum.Font.GothamBold
            timeLabel.TextSize = 18
            timeLabel.TextColor3 = TextColor
            timeLabel.BackgroundTransparency = 1
            timeLabel.TextXAlignment = "Left"

            -- AM/PM Tag
            local ampmBox = Instance.new("Frame", statBox)
            ampmBox.Size = UDim2.new(0, 25, 0, 12)
            ampmBox.Position = UDim2.new(0, 85, 0, 10)
            ampmBox.BackgroundColor3 = DarkPink
            Instance.new("UICorner", ampmBox).CornerRadius = UDim.new(0, 4)
            local ampmLabel = Instance.new("TextLabel", ampmBox)
            ampmLabel.Size = UDim2.new(1,0,1,0)
            ampmLabel.Text = "PM"
            ampmLabel.TextColor3 = Color3.new(1,1,1)
            ampmLabel.TextSize = 8
            ampmLabel.Font = Enum.Font.GothamBold
            ampmLabel.BackgroundTransparency = 1

            -- Múi giờ (UTC)
            local utcLabel = Instance.new("TextLabel", statBox)
            utcLabel.Size = UDim2.new(1, 0, 0, 10)
            utcLabel.Position = UDim2.new(0, 5, 0, 28)
            utcLabel.Text = "UTC+7 / GMT+7"
            utcLabel.TextSize = 6
            utcLabel.TextColor3 = DarkPink
            utcLabel.BackgroundTransparency = 1
            utcLabel.TextXAlignment = "Left"

            -- Ngày tháng (Góc phải)
            local dateLabel = Instance.new("TextLabel", statBox)
            dateLabel.Size = UDim2.new(0.5, 0, 0, 10)
            dateLabel.Position = UDim2.new(0.4, 0, 0.7, 0)
            dateLabel.Text = os.date("%A, %b %d")
            dateLabel.TextSize = 7
            dateLabel.TextColor3 = TextColor
            dateLabel.BackgroundTransparency = 1
            dateLabel.TextXAlignment = "Right"

            -- UpTime Stat (Phần quan trọng)
            local upStat = Instance.new("TextLabel", statBox)
            upStat.Size = UDim2.new(0, 60, 0, 12)
            upStat.Position = UDim2.new(0, 45, 0, 42)
            upStat.BackgroundColor3 = Color3.new(1,1,1)
            upStat.BackgroundTransparency = 0.5
            upStat.Text = "Up: 0m 0s"
            upStat.TextSize = 7
            upStat.Font = Enum.Font.GothamBold
            upStat.TextColor3 = TextColor
            Instance.new("UICorner", upStat).CornerRadius = UDim.new(0, 4)

            -- Vòng lặp cập nhật
            task.spawn(function()
                while task.wait(1) do
                    -- Cập nhật đồng hồ
                    timeLabel.Text = os.date("%I:%M:%S")
                    ampmLabel.Text = os.date("%p")
                    
                    -- Tính UpTime
                    local diff = os.time() - startTime
                    local m = math.floor(diff / 60)
                    local s = diff % 60
                    upStat.Text = string.format("Up: %dm %ds", m, s)
                end
            end)
        end
        
        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.BackgroundTransparency = 0.5
            btn.Text = text
            btn.Font = Enum.Font.GothamSemibold
            btn.TextColor3 = TextColor
            btn.TextSize = 10
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
            btn.MouseButton1Click:Connect(callback)
        end
        
        if #sidebar:GetChildren() == 1 then page.Visible = true end
        return elements
    end

    return Library
end

