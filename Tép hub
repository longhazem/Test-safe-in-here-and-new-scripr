local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

-- Hệ thống âm thanh nối tiếp
local function PlayIntroSounds()
    local s1 = Instance.new("Sound", SoundService)
    s1.SoundId = "rbxassetid://87585111317596"
    s1.Volume = 1
    
    local s2 = Instance.new("Sound", SoundService)
    s2.SoundId = "rbxassetid://88375863598461"
    s2.Volume = 0.5
    s2.Looped = true

    s1:Play()
    s1.Ended:Wait()
    s2:Play()
end
task.spawn(PlayIntroSounds)

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    local MainColor = Color3.fromRGB(255, 192, 203) -- Màu hồng nhạt
    local TextColor = Color3.fromRGB(100, 50, 60)
    local AccentColor = Color3.fromRGB(255, 140, 160)

    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0.55, 0, 0.65, 0)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.2
    main.Parent = screenGui
    
    local uiSizeConstraint = Instance.new("UISizeConstraint", main)
    uiSizeConstraint.MaxSize = Vector2.new(750, 480)
    uiSizeConstraint.MinSize = Vector2.new(400, 300)

    Instance.new("UICorner", main).CornerRadius = UDim.new(0.05, 0)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.Thickness = 2
    mainStroke.Transparency = 0.5

    -- SIDEBAR
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0.08, 0, 0.8, 0)
    sidebar.Position = UDim2.new(0.91, 0, 0.1, 0)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.5
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(0.5, 0)

    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0.03, 0)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    -- TAB CONTAINER
    local tabContainer = Instance.new("Frame", main)
    tabContainer.Size = UDim2.new(0.85, 0, 0.9, 0)
    tabContainer.Position = UDim2.new(0.03, 0, 0.05, 0)
    tabContainer.BackgroundTransparency = 1

    local pages = Instance.new("Frame", tabContainer)
    pages.Size = UDim2.new(1, 0, 1, 0)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name .. "Page"
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0.48, 0, 0, 45)
        layout.CellPadding = UDim2.new(0.02, 0, 0.02, 0)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0.7, 0, 0.7, 0)
        Instance.new("UIAspectRatioConstraint", tabBtn).AspectRatio = 1
        tabBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        tabBtn.BackgroundTransparency = 0.8
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.TextScaled = true
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.TextColor3 = TextColor
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1, 0)

        tabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)

        local elements = {}

        -- --- PHẦN GIAO DIỆN HOME GIỐNG ẢNH ---
        function elements:AddDashboard()
            layout:Destroy() -- Xóa Grid layout để tự do sắp xếp
            
            -- Khung User (Trái Trên)
            local userFrame = Instance.new("Frame", page)
            userFrame.Size = UDim2.new(0.58, 0, 0.48, 0)
            userFrame.Position = UDim2.new(0, 0, 0, 0)
            userFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            userFrame.BackgroundTransparency = 0.5
            Instance.new("UICorner", userFrame).CornerRadius = UDim.new(0.1, 0)

            local pfp = Instance.new("ImageLabel", userFrame)
            pfp.Size = UDim2.new(0.4, 0, 0.8, 0)
            pfp.Position = UDim2.new(0.05, 0, 0.5, 0)
            pfp.AnchorPoint = Vector2.new(0, 0.5)
            pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
            pfp.BackgroundTransparency = 1
            Instance.new("UIAspectRatioConstraint", pfp)
            Instance.new("UICorner", pfp).CornerRadius = UDim.new(1, 0)

            local welcome = Instance.new("TextLabel", userFrame)
            welcome.Size = UDim2.new(0.5, 0, 0.4, 0)
            welcome.Position = UDim2.new(0.45, 0, 0.3, 0)
            welcome.Text = "The lanterns light your way~, \n" .. Players.LocalPlayer.DisplayName .. "!"
            welcome.Font = Enum.Font.GothamBold
            welcome.TextColor3 = TextColor
            welcome.TextScaled = true
            welcome.BackgroundTransparency = 1
            welcome.TextXAlignment = Enum.TextXAlignment.Left

            -- Khung About (Phải Trên)
            local aboutFrame = Instance.new("Frame", page)
            aboutFrame.Size = UDim2.new(0.38, 0, 0.48, 0)
            aboutFrame.Position = UDim2.new(0.62, 0, 0, 0)
            aboutFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            aboutFrame.BackgroundTransparency = 0.5
            Instance.new("UICorner", aboutFrame).CornerRadius = UDim.new(0.1, 0)

            local aboutTitle = Instance.new("TextLabel", aboutFrame)
            aboutTitle.Size = UDim2.new(1, 0, 0.2, 0)
            aboutTitle.Text = "About"
            aboutTitle.Font = Enum.Font.GothamBold
            aboutTitle.TextColor3 = TextColor
            aboutTitle.BackgroundTransparency = 1
            
            local aboutInfo = Instance.new("TextLabel", aboutFrame)
            aboutInfo.Size = UDim2.new(0.9, 0, 0.7, 0)
            aboutInfo.Position = UDim2.new(0.05, 0, 0.25, 0)
            aboutInfo.Text = "TOKAI HUB là hệ thống script hỗ trợ đa nền tảng, tập trung vào trải nghiệm người dùng tối ưu nhất."
            aboutInfo.Font = Enum.Font.Gotham
            aboutInfo.TextColor3 = TextColor
            aboutInfo.TextScaled = true
            aboutInfo.BackgroundTransparency = 1
            aboutInfo.TextWrapped = true

            -- Khung Status/Time (Dưới)
            local statusFrame = Instance.new("Frame", page)
            statusFrame.Size = UDim2.new(1, 0, 0.48, 0)
            statusFrame.Position = UDim2.new(0, 0, 0.52, 0)
            statusFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            statusFrame.BackgroundTransparency = 0.5
            Instance.new("UICorner", statusFrame).CornerRadius = UDim.new(0.1, 0)

            local timeLabel = Instance.new("TextLabel", statusFrame)
            timeLabel.Size = UDim2.new(0.4, 0, 0.5, 0)
            timeLabel.Position = UDim2.new(0.05, 0, 0.2, 0)
            timeLabel.Font = Enum.Font.GothamBold
            timeLabel.TextColor3 = TextColor
            timeLabel.TextScaled = true
            timeLabel.BackgroundTransparency = 1

            -- Cập nhật thời gian thực
            task.spawn(function()
                while task.wait(1) do
                    local t = os.date("*t")
                    timeLabel.Text = string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
                end
            end)

            local infoLabel = Instance.new("TextLabel", statusFrame)
            infoLabel.Size = UDim2.new(0.5, 0, 0.4, 0)
            infoLabel.Position = UDim2.new(0.45, 0, 0.25, 0)
            infoLabel.Text = "Status: Running\nVersion: 1.0.0\nExecutor: Premium"
            infoLabel.Font = Enum.Font.GothamSemibold
            infoLabel.TextColor3 = TextColor
            infoLabel.TextScaled = true
            infoLabel.BackgroundTransparency = 1
            infoLabel.TextXAlignment = Enum.TextXAlignment.Left
        end
        
        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.BackgroundTransparency = 0.4
            btn.Text = text
            btn.Font = Enum.Font.GothamSemibold
            btn.TextColor3 = TextColor
            btn.TextScaled = true
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0.2, 0)
            btn.MouseButton1Click:Connect(callback)
        end
        
        if #sidebar:GetChildren() == 1 then page.Visible = true end
        return elements
    end

    -- Kéo thả
    local dragging, dragStart, startPos
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)

    return Library
end

-- --- THỰC THI ---
local win = Library:CreateWindow()

-- 1. Tab Home (Giao diện Dashboard giống ảnh)
local homeTab = win:CreateTab("Home", "H")
homeTab:AddDashboard()

-- 2. Tab Main
local mainTab = win:CreateTab("Main", "M")
mainTab:AddButton("Auto Farm", function() print("Farm") end)

-- 3. Tab Setting
local settingTab = win:CreateTab("Setting", "S")
settingTab:AddButton("Destroy UI", function() CleanupOldUI() end)
