    local loadFrame = Instance.new("Frame", bgOverlay)
    loadFrame.Size = UDim2.new(0, 320, 0, 180) -- Tăng chiều cao một chút để logo thoáng hơn
    loadFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
