local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

-- Hệ thống âm thanh
local function PlayIntroSounds()
    local s1 = Instance.new("Sound", SoundService)
    s1.SoundId = "rbxassetid://87585111317596"
    s1.Volume = 1
    local s2 = Instance.new("Sound", SoundService)
    s2.SoundId = "rbxassetid://88375863598461"
    s2.Volume = 0.5
    s2.Looped = true
    s1:Play()
    s1.Ended:Wait()
    s2:Play()
end
task.spawn(PlayIntroSounds)

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    local MainColor = Color3.fromRGB(255, 170, 190)
    local TextColor = Color3.fromRGB(80, 40, 50)
    local DarkPink = Color3.fromRGB(220, 100, 130)

    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0, 720, 0, 440)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.25
    main.Parent = screenGui
    
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 20)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.Thickness = 2
    mainStroke.Transparency = 0.6

    -- SIDEBAR (RIGHT)
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 55, 0, 360)
    sidebar.Position = UDim2.new(1, -65, 0.5, -180)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.6
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(1, 0)

    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0, 15)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    -- TAB CONTAINER
    local tabContainer = Instance.new("Frame", main)
    tabContainer.Size = UDim2.new(0, 620, 0, 390)
    tabContainer.Position = UDim2.new(0, 20, 0, 25)
    tabContainer.BackgroundTransparency = 1

    local pages = Instance.new("Frame", tabContainer)
    pages.Size = UDim2.new(1, 0, 1, 0)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name .. "Page"
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0.48, 0, 0, 45)
        layout.CellPadding = UDim2.new(0.02, 0, 0.02, 0)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0, 40, 0, 40)
        tabBtn.BackgroundColor3 = DarkPink
        tabBtn.BackgroundTransparency = 0.2
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.TextScaled = true
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1, 0)

        tabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)

        local elements = {}

        -- --- HÀM HOME DASHBOARD ---
        function elements:AddDashboard()
            layout:Destroy() 
            
            local function CreateBox(size, pos, titleText)
                local box = Instance.new("Frame", page)
                box.Size = size
                box.Position = pos
                box.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                box.BackgroundTransparency = 0.5
                Instance.new("UICorner", box).CornerRadius = UDim.new(0, 15)
                
                if titleText then
                    local label = Instance.new("TextLabel", box)
                    label.Size = UDim2.new(0, 25, 1, 0)
                    label.Position = UDim2.new(1, -25, 0, 0)
                    label.Text = titleText
                    label.Font = Enum.Font.GothamBold
                    label.TextColor3 = DarkPink
                    label.TextSize = 10
                    label.TextWrapped = true
                    label.BackgroundTransparency = 1
                    label.Rotation = 0 -- Chữ dọc kiểu Nhật/Ảnh
                end
                return box
            end

            -- 1. USER BOX (Top Left)
            local userBox = CreateBox(UDim2.new(0.6, 0, 0.47, 0), UDim2.new(0, 0, 0, 0))
            local pfp = Instance.new("ImageLabel", userBox)
            pfp.Size = UDim2.new(0, 120, 0, 120)
            pfp.Position = UDim2.new(0, 15, 0.5, -60)
            pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
            pfp.BackgroundColor3 = DarkPink
            pfp.BackgroundTransparency = 0.3
            Instance.new("UICorner", pfp).CornerRadius = UDim.new(1, 0)

            local greet = Instance.new("TextLabel", userBox)
            greet.Size = UDim2.new(0.5, 0, 0.5, 0)
            greet.Position = UDim2.new(0, 150, 0.2, 0)
            greet.Text = "The lanterns light your way~,\n" .. Players.LocalPlayer.DisplayName .. "!"
            greet.Font = Enum.Font.GothamBold
            greet.TextColor3 = TextColor
            greet.TextSize = 18
            greet.TextXAlignment = "Left"
            greet.BackgroundTransparency = 1

            local dots = Instance.new("TextLabel", userBox)
            dots.Position = UDim2.new(0.5, 0, 0.9, -10)
            dots.Text = "● ○ ○"
            dots.TextColor3 = DarkPink
            dots.BackgroundTransparency = 1

            -- 2. ABOUT BOX (Top Right)
            local aboutBox = CreateBox(UDim2.new(0.37, 0, 0.47, 0), UDim2.new(0.63, 0, 0, 0), "A\nB\nO\nU\nT")
            local aboutDesc = Instance.new("TextLabel", aboutBox)
            aboutDesc.Size = UDim2.new(0.8, 0, 0.7, 0)
            aboutDesc.Position = UDim2.new(0.05, 0, 0.15, 0)
            aboutDesc.Text = "Yae Miko is the head shrine maiden of the Grand Narukami Shrine and the owner of the Yae Publishing House."
            aboutDesc.Font = Enum.Font.Gotham
            aboutDesc.TextColor3 = TextColor
            aboutDesc.TextSize = 13
            aboutDesc.TextWrapped = true
            aboutDesc.TextXAlignment = "Left"
            aboutDesc.BackgroundTransparency = 1

            -- 3. MUSIC BOX (Bottom Left)
            local musicBox = CreateBox(UDim2.new(0.35, 0, 0.47, 0), UDim2.new(0, 0, 0.53, 0), "M\nU\nS\nI\nC")
            local runningText = Instance.new("TextLabel", musicBox)
            runningText.Text = "Running"
            runningText.Size = UDim2.new(1,0,0.2,0)
            runningText.TextColor3 = DarkPink
            runningText.BackgroundTransparency = 1
            
            local visualizer = Instance.new("TextLabel", musicBox)
            visualizer.Size = UDim2.new(1, 0, 0.5, 0)
            visualizer.Position = UDim2.new(0, 0, 0.4, 0)
            visualizer.Text = "●●●●●●●●●●●●●"
            visualizer.TextColor3 = DarkPink
            visualizer.BackgroundTransparency = 1

            -- 4. STATUS/TIME BOX (Bottom Right)
            local statBox = CreateBox(UDim2.new(0.62, 0, 0.47, 0), UDim2.new(0.38, 0, 0.53, 0), "S\nT\nA\nT\nU\nS")
            
            local timeLabel = Instance.new("TextLabel", statBox)
            timeLabel.Size = UDim2.new(0, 150, 0, 50)
            timeLabel.Position = UDim2.new(0, 15, 0, 10)
            timeLabel.Font = Enum.Font.GothamBold
            timeLabel.TextSize = 35
            timeLabel.TextColor3 = TextColor
            timeLabel.BackgroundTransparency = 1

            local dateLabel = Instance.new("TextLabel", statBox)
            dateLabel.Position = UDim2.new(1, -150, 0, 20)
            dateLabel.Text = os.date("%A, %B %d")
            dateLabel.TextColor3 = DarkPink
            dateLabel.BackgroundTransparency = 1

            -- Stats Row
            local statsRow = Instance.new("Frame", statBox)
            statsRow.Size = UDim2.new(0.9, 0, 0.3, 0)
            statsRow.Position = UDim2.new(0, 15, 0, 65)
            statsRow.BackgroundTransparency = 1
            local statsLayout = Instance.new("UIListLayout", statsRow)
            statsLayout.FillDirection = "Horizontal"
            statsLayout.Padding = UDim.new(0, 8)

            local function AddStat(txt)
                local s = Instance.new("TextLabel", statsRow)
                s.Size = UDim2.new(0, 65, 1, 0)
                s.BackgroundColor3 = Color3.new(1,1,1)
                s.BackgroundTransparency = 0.5
                s.Text = txt
                s.TextSize = 10
                s.Font = Enum.Font.GothamBold
                s.TextColor3 = TextColor
                Instance.new("UICorner", s).CornerRadius = UDim.new(0, 5)
            end
            AddStat("Exec: 4")
            AddStat("Up: 20m")
            AddStat("Sess: 9s")
            AddStat("Via: Tokai")

            task.spawn(function()
                while task.wait(1) do
                    timeLabel.Text = os.date("%H:%M:%S")
                end
            end)
        end
        
        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.BackgroundTransparency = 0.4
            btn.Text = text
            btn.Font = Enum.Font.GothamSemibold
            btn.TextColor3 = TextColor
            btn.TextSize = 14
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
            btn.MouseButton1Click:Connect(callback)
        end
        
        if #sidebar:GetChildren() == 1 then page.Visible = true end
        return elements
    end

    -- Kéo thả (Draggable)
    local dragging, dragStart, startPos
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)

    return Library
end

