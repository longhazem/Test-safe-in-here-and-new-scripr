local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local startTime = os.time()
_G.ToggleKey = Enum.KeyCode.RightControl
local isLocked = false 

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

local function PlayClickSound()
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://126347354635406"
    sound.Volume = 0.6
    sound.Parent = SoundService
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 2)
end

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    local MainColor = Color3.fromRGB(255, 182, 193)
    local TextColor = Color3.fromRGB(90, 45, 55)
    local DarkPink = Color3.fromRGB(235, 110, 140)

    -- // NÚT MỞ (MOBILE) // --
    local openBtn = Instance.new("ImageButton", screenGui)
    openBtn.Name = "OpenButton"
    openBtn.Size = UDim2.new(0, 50, 0, 50)
    openBtn.Position = UDim2.new(0, 10, 0.5, -25)
    openBtn.BackgroundColor3 = MainColor
    openBtn.Image = "rbxthumb://type=Asset&id=99217897221957&w=420&h=420"
    openBtn.Visible = false
    Instance.new("UICorner", openBtn).CornerRadius = UDim.new(1, 0)
    local openStroke = Instance.new("UIStroke", openBtn)
    openStroke.Thickness = 3

    -- MAIN FRAME
    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0, 364, 0, 240)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.3
    main.Parent = screenGui
    main.ClipsDescendants = false 
    
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 15)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Thickness = 2

    -- // TOOLBAR BÊN PHẢI // --
    local toolbar = Instance.new("Frame", main)
    toolbar.Name = "Toolbar"
    toolbar.Size = UDim2.new(0, 35, 0, 100)
    toolbar.Position = UDim2.new(1, 5, 0, 10)
    toolbar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    toolbar.BackgroundTransparency = 0.7
    Instance.new("UICorner", toolbar).CornerRadius = UDim.new(0, 10)
    local toolLayout = Instance.new("UIListLayout", toolbar)
    toolLayout.Padding = UDim.new(0, 5)
    toolLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    toolLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    local function CreateToolBtn(icon, color)
        local b = Instance.new("TextButton", toolbar)
        b.Size = UDim2.new(0, 25, 0, 25)
        b.BackgroundColor3 = color or DarkPink
        b.Text = icon
        b.TextColor3 = Color3.new(1, 1, 1)
        b.Font = Enum.Font.GothamBold
        b.TextSize = 16
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
        return b
    end

    local closeTool = CreateToolBtn("-", Color3.fromRGB(255, 100, 100)) -- Nút tắt bằng dấu -
    local bindTool = CreateToolBtn("⌨", DarkPink)
    local lockTool = CreateToolBtn("🔓", Color3.fromRGB(100, 200, 100))

    -- Rainbow Stroke
    coroutine.wrap(function()
        local colors = {Color3.fromRGB(255,255,255), Color3.fromRGB(255,192,203), Color3.fromRGB(230,190,255)}
        while task.wait() do
            local t = (math.sin(tick() * 2) + 1) / 2
            local targetColor = colors[1]:Lerp(colors[2], t):Lerp(colors[3], (math.cos(tick()*1.5)+1)/2)
            mainStroke.Color = targetColor
            openStroke.Color = targetColor
        end
    end)()

    local MainSize = UDim2.new(0, 364, 0, 240)
    local isToggling = false
    local function ToggleUI()
        if isToggling then return end
        isToggling = true
        if main.Visible then
            local tw = TweenService:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
            tw:Play()
            tw.Completed:Connect(function()
                main.Visible = false
                if openBtn.Parent then openBtn.Visible = true end
                isToggling = false
            end)
        else
            openBtn.Visible = false
            main.Visible = true
            main.Size = UDim2.new(0, 0, 0, 0)
            local tw = TweenService:Create(main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = MainSize})
            tw:Play()
            tw.Completed:Connect(function() isToggling = false end)
        end
    end

    -- Toolbar Logic
    closeTool.MouseButton1Click:Connect(function() PlayClickSound(); ToggleUI() end)
    
    local binding = false
    bindTool.MouseButton1Click:Connect(function()
        if binding then return end
        PlayClickSound()
        binding = true
        bindTool.Text = "..."
        
        local connection
        connection = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                _G.ToggleKey = input.KeyCode
                bindTool.Text = "⌨"
                binding = false
                connection:Disconnect()
            elseif input.UserInputType == Enum.UserInputType.Touch then
                -- Mobile ẩn hoàn toàn UI nhỏ
                openBtn.Visible = false
                bindTool.Text = "⌨"
                binding = false
                connection:Disconnect()
            end
        end)
    end)

    lockTool.MouseButton1Click:Connect(function()
        PlayClickSound()
        isLocked = not isLocked
        lockTool.Text = isLocked and "🔒" or "🔓"
        lockTool.BackgroundColor3 = isLocked and Color3.fromRGB(200, 50, 50) or Color3.fromRGB(100, 200, 100)
    end)

    openBtn.MouseButton1Click:Connect(function() PlayClickSound(); ToggleUI() end)
    
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == _G.ToggleKey then 
            PlayClickSound()
            ToggleUI() 
        end
    end)

    -- Kéo UI
    local function EnableDrag(obj)
        local dragging, dragInput, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if isLocked then return end
            if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
                dragging = true
                dragStart = input.Position
                startPos = obj.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        obj.InputChanged:Connect(function(input)
            if isLocked then return end
            if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                dragInput = input
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging and not isLocked then
                local delta = input.Position - dragStart
                obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end
    EnableDrag(main); EnableDrag(openBtn)

    -- Tabs System
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 35, 0, 180)
    sidebar.Position = UDim2.new(1, -40, 0.5, -90)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.7
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(1, 0)
    Instance.new("UIListLayout", sidebar).Padding = UDim.new(0, 8)
    sidebar.UIListLayout.HorizontalAlignment = "Center"
    sidebar.UIListLayout.VerticalAlignment = "Center"

    local pages = Instance.new("Frame", main)
    pages.Size = UDim2.new(0, 300, 0, 210)
    pages.Position = UDim2.new(0, 10, 0, 15)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name .. "Page"
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        page.AutomaticCanvasSize = "Y"

        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0.48, 0, 0, 35)
        layout.CellPadding = UDim2.new(0.02, 0, 0.02, 0)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0, 28, 0, 28)
        tabBtn.BackgroundColor3 = DarkPink
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.Font = "GothamBold"; tabBtn.TextColor3 = Color3.new(1,1,1); tabBtn.TextScaled = true
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1,0)

        tabBtn.MouseButton1Click:Connect(function()
            PlayClickSound()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)

        local elements = {}

        function elements:AddDashboard()
            layout:Destroy() 
            local function CreateBox(size, pos, titleText)
                local box = Instance.new("Frame", page)
                box.Size = size; box.Position = pos
                box.BackgroundColor3 = Color3.new(1,1,1); box.BackgroundTransparency = 0.6
                Instance.new("UICorner", box).CornerRadius = UDim.new(0,10)
                if titleText then
                    local bar = Instance.new("Frame", box)
                    bar.Size = UDim2.new(0,15,1,0); bar.Position = UDim2.new(1,-15,0,0)
                    bar.BackgroundColor3 = DarkPink; Instance.new("UICorner", bar).CornerRadius = UDim.new(0,10)
                    local l = Instance.new("TextLabel", bar)
                    l.Size = UDim2.new(1,0,1,0); l.Text = titleText; l.TextColor3 = Color3.new(1,1,1)
                    l.TextSize = 6; l.Font = "GothamBold"; l.TextWrapped = true; l.BackgroundTransparency = 1
                end
                return box
            end

            local uBox = CreateBox(UDim2.new(0.6, -5, 0.48, 0), UDim2.new(0,0,0,0), "U\nS\nE\nR")
            local pfp = Instance.new("ImageLabel", uBox)
            pfp.Size = UDim2.new(0,45,0,45); pfp.Position = UDim2.new(0,5,0.5,-22.5)
            pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, "HeadShot", "Size100x100")
            pfp.BackgroundTransparency = 1; Instance.new("UICorner", pfp).CornerRadius = UDim.new(1,0)
            
            local g = Instance.new("TextLabel", uBox)
            g.Size = UDim2.new(0.5,0,0.8,0); g.Position = UDim2.new(0,55,0.1,0)
            g.Text = "Hi, oniichan!\n" .. Players.LocalPlayer.DisplayName; g.Font = "GothamBold"; g.TextSize = 8
            g.TextColor3 = TextColor; g.TextXAlignment = "Left"; g.BackgroundTransparency = 1

            local sBox = CreateBox(UDim2.new(1, 0, 0.48, 0), UDim2.new(0,0,0.52,0), "S\nT\nA\nT\nU\nS")
            local tL = Instance.new("TextLabel", sBox)
            tL.Size = UDim2.new(1,-20,0.4,0); tL.Position = UDim2.new(0,5,0.1,0)
            tL.Font = "GothamBold"; tL.TextSize = 14; tL.TextColor3 = TextColor; tL.BackgroundTransparency = 1

            local uL = Instance.new("TextLabel", sBox)
            uL.Size = UDim2.new(1,-20,0.3,0); uL.Position = UDim2.new(0,5,0.6,0)
            uL.Font = "GothamBold"; uL.TextSize = 8; uL.TextColor3 = DarkPink; uL.BackgroundTransparency = 1

            task.spawn(function()
                while task.wait(1) do
                    tL.Text = os.date("%I:%M:%S %p")
                    local d = os.time() - startTime
                    uL.Text = string.format("Uptime: %dm %ds", math.floor(d/60), d%60)
                end
            end)
        end
        
        function elements:AddButton(text, cb)
            local b = Instance.new("TextButton", page)
            b.BackgroundColor3 = Color3.new(1,1,1); b.BackgroundTransparency = 0.5
            b.Text = text; b.Font = "GothamSemibold"; b.TextColor3 = TextColor; b.TextSize = 10
            Instance.new("UICorner", b).CornerRadius = UDim.new(0,5)
            b.MouseButton1Click:Connect(function() PlayClickSound(); cb() end)
        end
        
        if #sidebar:GetChildren() == 2 then page.Visible = true end -- Vì có UIListLayout nên dùng 2
        return elements
    end
    return Library
end

local win = Library:CreateWindow()
local h = win:CreateTab("Home", "H")
h:AddDashboard()

local m = win:CreateTab("Main", "M")
m:AddButton("Click Test", function() print("TokaiHub Working!") end)
