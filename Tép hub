local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local startTime = os.time()
_G.ToggleKey = Enum.KeyCode.RightControl

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

local function PlayClickSound()
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://126347354635406"
    sound.Volume = 0.6
    sound.Parent = SoundService
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 2)
end

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    -- // ÂM THANH KHI BẬT HUB // --
    local openSound = Instance.new("Sound")
    openSound.SoundId = "rbxassetid://90621979353525"
    openSound.Volume = 1
    openSound.Parent = SoundService
    openSound:Play()
    game:GetService("Debris"):AddItem(openSound, 5)

    local MainColor = Color3.fromRGB(255, 182, 193)
    local TextColor = Color3.fromRGB(90, 45, 55)
    local DarkPink = Color3.fromRGB(235, 110, 140)
    local MainSize = UDim2.new(0, 364, 0, 240)

    -- // NÚT MỞ UI (OPEN BUTTON) // --
    local openBtn = Instance.new("ImageButton", screenGui)
    openBtn.Name = "OpenButton"
    openBtn.Size = UDim2.new(0, 50, 0, 50)
    openBtn.Position = UDim2.new(0, 10, 0.5, -25)
    openBtn.BackgroundColor3 = MainColor
    openBtn.Image = "rbxthumb://type=Asset&id=99217897221957&w=420&h=420"
    openBtn.Visible = false
    Instance.new("UICorner", openBtn).CornerRadius = UDim.new(1, 0)
    local openStroke = Instance.new("UIStroke", openBtn)
    openStroke.Thickness = 3

    -- MAIN FRAME
    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = MainSize
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.3
    main.Parent = screenGui
    main.ClipsDescendants = true
    
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 15)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Thickness = 2.5

    -- // LOGIC ĐÓNG MỞ (TOGGLE UI) // --
    local isToggling = false
    local function ToggleUI()
        if isToggling then return end
        isToggling = true
        if main.Visible then
            local tw = TweenService:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
            tw:Play()
            tw.Completed:Connect(function()
                main.Visible = false
                openBtn.Visible = true
                isToggling = false
            end)
        else
            openBtn.Visible = false
            main.Visible = true
            main.Size = UDim2.new(0, 0, 0, 0)
            local tw = TweenService:Create(main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = MainSize})
            tw:Play()
            tw.Completed:Connect(function() isToggling = false end)
        end
    end

    openBtn.MouseButton1Click:Connect(function() PlayClickSound(); ToggleUI() end)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == _G.ToggleKey then PlayClickSound(); ToggleUI() end
    end)

    -- // HIỆU ỨNG VIỀN MÀU: TRẮNG - HỒNG - TÍM NHẠT // --
    coroutine.wrap(function()
        local colors = {
            Color3.fromRGB(255, 255, 255), -- Trắng
            Color3.fromRGB(255, 182, 193), -- Hồng
            Color3.fromRGB(200, 160, 255)  -- Tím nhạt
        }
        local i = 0
        while screenGui.Parent do
            i = i + 1
            local colorA = colors[1]
            local colorB = colors[2]
            local colorC = colors[3]
            
            -- Tạo hiệu ứng chuyển màu mượt mà (Lerp)
            local t = (math.sin(tick() * 2) + 1) / 2
            local targetColor = colorA:Lerp(colorB, t):Lerp(colorC, (math.cos(tick() * 2) + 1) / 2)
            
            mainStroke.Color = targetColor
            openStroke.Color = targetColor
            task.wait()
        end
    end)()

    -- KÉO UI (Hỗ trợ PC & Mobile)
    local function EnableDrag(obj)
        local dragging, dragInput, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = obj.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        obj.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
        RunService.RenderStepped:Connect(function()
            if dragging and dragInput then
                local delta = dragInput.Position - dragStart
                obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end
    EnableDrag(main); EnableDrag(openBtn)

    -- Sidebar & Các thành phần khác giữ nguyên logic cũ của bạn
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 35, 0, 180)
    sidebar.Position = UDim2.new(1, -40, 0.5, -90)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.7
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(1, 0)

    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0, 8)
    sideLayout.HorizontalAlignment = "Center"; sideLayout.VerticalAlignment = "Center"

    local tabContainer = Instance.new("Frame", main)
    tabContainer.Size = UDim2.new(0, 310, 0, 200)
    tabContainer.Position = UDim2.new(0, 10, 0, 15)
    tabContainer.BackgroundTransparency = 1

    local pages = Instance.new("Frame", tabContainer)
    pages.Size = UDim2.new(1, 0, 1, 0); pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name .. "Page"; page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1; page.Visible = false; page.ScrollBarThickness = 0
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0.48, 0, 0, 35); layout.CellPadding = UDim2.new(0.02, 0, 0.02, 0)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0, 28, 0, 28)
        tabBtn.BackgroundColor3 = DarkPink; tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.TextScaled = true; tabBtn.Font = "GothamBold"; tabBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1, 0)

        tabBtn.MouseButton1Click:Connect(function()
            PlayClickSound()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)

        local elements = {}
        function elements:AddDashboard()
            layout:Destroy() 
            local function CreateBox(size, pos, titleText)
                local box = Instance.new("Frame", page)
                box.Size = size; box.Position = pos
                box.BackgroundColor3 = Color3.new(1,1,1); box.BackgroundTransparency = 0.6
                Instance.new("UICorner", box).CornerRadius = UDim.new(0, 10)
                if titleText then
                    local bar = Instance.new("Frame", box)
                    bar.Size = UDim2.new(0, 18, 1, 0); bar.Position = UDim2.new(1, -18, 0, 0)
                    bar.BackgroundColor3 = DarkPink; Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 10)
                    local label = Instance.new("TextLabel", bar)
                    label.Size = UDim2.new(1,0,1,0); label.Text = titleText; label.Font = "GothamBold"
                    label.TextColor3 = Color3.new(1,1,1); label.TextSize = 7; label.TextWrapped = true; label.BackgroundTransparency = 1
                end
                return box
            end

            local userBox = CreateBox(UDim2.new(0.6, 0, 0.47, 0), UDim2.new(0, 0, 0, 0))
            local pfp = Instance.new("ImageLabel", userBox)
            pfp.Size = UDim2.new(0, 50, 0, 50); pfp.Position = UDim2.new(0, 5, 0.5, -25)
            pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, "HeadShot", "Size100x100")
            pfp.BackgroundTransparency = 1; Instance.new("UICorner", pfp).CornerRadius = UDim.new(1, 0)

            local greet = Instance.new("TextLabel", userBox)
            greet.Size = UDim2.new(0.6, 0, 0.5, 0); greet.Position = UDim2.new(0, 60, 0.25, 0)
            greet.Text = "konnichiwa oniichan❤️,\n" .. Players.LocalPlayer.DisplayName
            greet.Font = "GothamBold"; greet.TextColor3 = TextColor; greet.TextSize = 8; greet.TextXAlignment = "Left"; greet.BackgroundTransparency = 1

            local statBox = CreateBox(UDim2.new(0.62, 0, 0.47, 0), UDim2.new(0.38, 0, 0.53, 0), "S\nT\nA\nT\nU\nS")
            local timeLabel = Instance.new("TextLabel", statBox)
            timeLabel.Size = UDim2.new(1, -25, 0.6, 0); timeLabel.Position = UDim2.new(0, 5, 0, 5)
            timeLabel.Font = "GothamBold"; timeLabel.TextSize = 16; timeLabel.TextColor3 = TextColor; timeLabel.BackgroundTransparency = 1; timeLabel.TextXAlignment = "Left"

            task.spawn(function()
                while task.wait(1) do
                    timeLabel.Text = os.date("%I:%M:%S")
                end
            end)
        end

        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = Color3.new(1,1,1); btn.BackgroundTransparency = 0.5
            btn.Text = text; btn.Font = "GothamSemibold"; btn.TextColor3 = TextColor; btn.TextSize = 10
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
            btn.MouseButton1Click:Connect(function() PlayClickSound(); callback() end)
        end

        if #sidebar:GetChildren() == 1 then page.Visible = true end
        return elements
    end
    return Library
end

-- --- KHỞI CHẠY ---
local win = Library:CreateWindow()
local homeTab = win:CreateTab("Home", "H")
homeTab:AddDashboard()

local mainTab = win:CreateTab("Main", "M")
mainTab:AddButton("Test Button", function() print("Clicked!") end)
mainTab:AddButton("Destroy UI", function() CleanupOldUI() end)
