local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
    if SoundService:FindFirstChild("TOKAI_LOAD_SOUND") then
        SoundService:FindFirstChild("TOKAI_LOAD_SOUND"):Destroy()
    end
end
CleanupOldUI()

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    local MainColor = Color3.fromRGB(255, 192, 203)
    local TextColor = Color3.fromRGB(100, 50, 60)

    -- SOUND
    local loadSound = Instance.new("Sound")
    loadSound.Name = "TOKAI_LOAD_SOUND"
    loadSound.SoundId = "rbxassetid://87585111317596"
    loadSound.Volume = 0.6
    loadSound.Parent = SoundService

    -- LOADER UI
    local loader = Instance.new("Frame", screenGui)
    loader.Size = UDim2.new(1, 0, 1, 0)
    loader.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    loader.ZIndex = 100

    local logo = Instance.new("ImageLabel", loader)
    logo.Size = UDim2.new(0, 120, 0, 120)
    -- Vị trí rơi ngẫu nhiên từ trên đỉnh
    logo.Position = UDim2.new(math.random(15, 85)/100, 0, -0.2, 0)
    logo.AnchorPoint = Vector2.new(0.5, 0.5)
    logo.BackgroundTransparency = 1
    logo.Image = "rbxassetid://137658875383845"
    logo.ZIndex = 101

    local barBg = Instance.new("Frame", loader)
    barBg.Size = UDim2.new(0.3, 0, 0, 3)
    barBg.Position = UDim2.new(0.5, 0, 0.8, 0)
    barBg.AnchorPoint = Vector2.new(0.5, 0.5)
    barBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    barBg.BackgroundTransparency = 1
    barBg.BorderSizePixel = 0
    Instance.new("UICorner", barBg)

    local bar = Instance.new("Frame", barBg)
    bar.Size = UDim2.new(0, 0, 1, 0)
    bar.BackgroundColor3 = MainColor
    bar.BorderSizePixel = 0
    Instance.new("UICorner", bar)

    -- MAIN FRAME
    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0.5, 0, 0.6, 0)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 1
    main.Visible = false
    main.Parent = screenGui

    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.Thickness = 2
    mainStroke.Transparency = 1
    Instance.new("UICorner", main).CornerRadius = UDim.new(0.05, 0)

    -- (Phần Profile & About giữ nguyên như cũ)
    local profileFrame = Instance.new("Frame", main)
    profileFrame.Size = UDim2.new(0.45, 0, 0.45, 0)
    profileFrame.Position = UDim2.new(0.04, 0, 0.06, 0)
    profileFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    profileFrame.BackgroundTransparency = 0.6
    Instance.new("UICorner", profileFrame).CornerRadius = UDim.new(0.1, 0)

    local pfp = Instance.new("ImageLabel", profileFrame)
    pfp.Size = UDim2.new(0.4, 0, 0.8, 0)
    pfp.Position = UDim2.new(0.05, 0, 0.5, 0)
    pfp.AnchorPoint = Vector2.new(0, 0.5)
    pfp.BackgroundTransparency = 1
    pfp.Image = Players:GetUserThumbnailAsync(Players.LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
    Instance.new("UICorner", pfp).CornerRadius = UDim.new(1, 0)

    local welcomeMsg = Instance.new("TextLabel", profileFrame)
    welcomeMsg.Size = UDim2.new(0.5, 0, 0.8, 0)
    welcomeMsg.Position = UDim2.new(0.45, 0, 0.5, 0)
    welcomeMsg.AnchorPoint = Vector2.new(0, 0.5)
    welcomeMsg.BackgroundTransparency = 1
    welcomeMsg.Text = "Welcome,\n" .. Players.LocalPlayer.DisplayName .. "!"
    welcomeMsg.TextColor3 = TextColor
    welcomeMsg.Font = Enum.Font.GothamBold
    welcomeMsg.TextScaled = true
    welcomeMsg.TextXAlignment = Enum.TextXAlignment.Left

    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0.1, 0, 0.8, 0)
    sidebar.Position = UDim2.new(1.02, 0, 0.1, 0)
    sidebar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sidebar.BackgroundTransparency = 0.5
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(0.3, 0)

    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0.05, 0)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    local pages = Instance.new("Frame", main)
    pages.Size = UDim2.new(0.92, 0, 0.4, 0)
    pages.Position = UDim2.new(0.04, 0, 0.55, 0)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        Instance.new("UIGridLayout", page).CellSize = UDim2.new(0.48, 0, 0, 40)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0.7, 0, 0.7, 0)
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.TextColor3 = TextColor
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1, 0)

        tabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)
        
        local elements = {}
        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.Text = text
            btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            btn.BackgroundTransparency = 0.4
            Instance.new("UICorner", btn)
            btn.MouseButton1Click:Connect(callback)
        end
        function elements:AddDiscordButton(link)
            local btn = Instance.new("TextButton", page)
            btn.Text = "DISCORD"
            btn.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
            btn.TextColor3 = Color3.fromRGB(255,255,255)
            Instance.new("UICorner", btn)
            btn.MouseButton1Click:Connect(function() setclipboard(link) end)
        end
        
        if #sidebar:GetChildren() == 2 then page.Visible = true end
        return elements
    end

    -- LOGIC LOADING (6 SECONDS TOTAL)
    task.spawn(function()
        loadSound:Play()

        -- 1. Rơi (1.2s)
        local fall = TweenService:Create(logo, TweenInfo.new(1.2, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out), {Position = UDim2.new(logo.Position.X.Scale, 0, 0.5, 0)})
        fall:Play()
        fall.Completed:Wait()

        -- 2. Lăn về giữa (1.5s)
        local roll = TweenService:Create(logo, TweenInfo.new(1.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, 0, 0.5, 0), Rotation = 720})
        roll:Play()
        roll.Completed:Wait()

        -- 3. Nhảy & Hiện Bar (0.5s nhảy + 2.5s load)
        TweenService:Create(logo, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, 0, 0.45, 0), Size = UDim2.new(0, 150, 0, 150)}):Play()
        
        barBg.BackgroundTransparency = 0.5
        local progress = TweenService:Create(bar, TweenInfo.new(2.8, Enum.EasingStyle.Linear), {Size = UDim2.new(1, 0, 1, 0)})
        progress:Play()
        progress.Completed:Wait()

        -- 4. Fade Out (0.5s)
        TweenService:Create(loadSound, TweenInfo.new(0.5), {Volume = 0}):Play()
        local fade = TweenService:Create(loader, TweenInfo.new(0.5), {BackgroundTransparency = 1})
        TweenService:Create(logo, TweenInfo.new(0.5), {ImageTransparency = 1}):Play()
        TweenService:Create(barBg, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        TweenService:Create(bar, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        fade:Play()
        
        fade.Completed:Connect(function()
            loader:Destroy()
            loadSound:Stop()
            main.Visible = true
            TweenService:Create(main, TweenInfo.new(0.5), {BackgroundTransparency = 0.2}):Play()
            TweenService:Create(mainStroke, TweenInfo.new(0.5), {Transparency = 0.5}):Play()
        end)
    end)

    -- Dragging Logic
    local dragging, dragStart, startPos
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)

    return Library
end

-- SỬ DỤNG
local win = Library:CreateWindow()
local mainTab = win:CreateTab("Home", "H")
mainTab:AddDiscordButton("https://discord.gg/nn783R2fK2")
mainTab:AddButton("Destroy UI", function() CleanupOldUI() end)
