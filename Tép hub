    loadFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", loadFrame).CornerRadius = UDim.new(0, 12)
    local loadStroke = Instance.new("UIStroke", loadFrame)
    loadStroke.Thickness = 2
    
    local glowFrame = Instance.new("ImageLabel", loadFrame)
    glowFrame.Size = UDim2.new(1, 60, 1, 60)
    glowFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    glowFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    glowFrame.BackgroundTransparency = 1
    glowFrame.Image = "rbxassetid://6014264795"
    glowFrame.ImageTransparency = 0.5
    glowFrame.ZIndex = 0

    -- Ảnh Loading Custom được làm to và rõ ràng hơn
    local customLogo = Instance.new("ImageLabel", loadFrame)
    customLogo.Size = UDim2.new(0, 75, 0, 75)
    customLogo.Position = UDim2.new(0.5, 0, 0, 15)
    customLogo.AnchorPoint = Vector2.new(0.5, 0)
    customLogo.BackgroundTransparency = 1
    customLogo.Image = loadingLogoID
    customLogo.ScaleType = Enum.ScaleType.Fit
    Instance.new("UICorner", customLogo).CornerRadius = UDim.new(0, 8)

    local title = Instance.new("TextLabel", loadFrame)
    title.Size = UDim2.new(1, 0, 0, 20)
    title.Position = UDim2.new(0, 0, 0, 100)
    title.BackgroundTransparency = 1
    title.Text = "TOKAI HUB"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 18

    local status = Instance.new("TextLabel", loadFrame)
    status.Size = UDim2.new(1, 0, 0, 15)
    status.Position = UDim2.new(0, 0, 0, 125)
    status.BackgroundTransparency = 1
    status.Text = "Đang tải dữ liệu..."
    status.TextColor3 = Color3.fromRGB(180, 180, 180)
    status.Font = Enum.Font.Gotham
    status.TextSize = 12

    local barBg = Instance.new("Frame", loadFrame)
    barBg.Size = UDim2.new(0, 260, 0, 6)
    barBg.Position = UDim2.new(0.5, 0, 0, 155)
    barBg.AnchorPoint = Vector2.new(0.5, 0)
    barBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", barBg).CornerRadius = UDim.new(1, 0)

    local barFill = Instance.new("Frame", barBg)
    barFill.Size = UDim2.new(0, 0, 1, 0)
    barFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", barFill).CornerRadius = UDim.new(1, 0)
    local fillStroke = Instance.new("UIStroke", barFill)
    fillStroke.Thickness = 1

    -- Hiệu ứng RGB cho Loading UI
    local rgbConnection = RunService.RenderStepped:Connect(function()
        local h = tick() % 5 / 5
        local color = Color3.fromHSV(h, 0.7, 1)
        loadStroke.Color = color
        glowFrame.ImageColor3 = color
        barFill.BackgroundColor3 = color
        fillStroke.Color = color
    end)

    -- Animation chữ chạy
    task.spawn(function()
        local texts = {"Đang khởi tạo...", "Đang tải tài nguyên...", "Xác thực bảo mật...", "Sắp xong rồi..."}
        for i = 1, #texts do
            status.Text = texts[i]
            task.wait(0.6)
        end
    end)

    local tweenFill = TweenService:Create(barFill, TweenInfo.new(2.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 1, 0)})
    tweenFill:Play()
    tweenFill.Completed:Wait()

    status.Text = "Tải hoàn tất!"
    task.wait(0.3)

    -- Hiệu ứng Fade Out
    local fadeOutInfo = TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    TweenService:Create(loadFrame, fadeOutInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(bgOverlay, fadeOutInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(customLogo, fadeOutInfo, {ImageTransparency = 1}):Play()
    TweenService:Create(title, fadeOutInfo, {TextTransparency = 1}):Play()
    TweenService:Create(status, fadeOutInfo, {TextTransparency = 1}):Play()
    TweenService:Create(barBg, fadeOutInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(barFill, fadeOutInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(loadStroke, fadeOutInfo, {Transparency = 1}):Play()
    TweenService:Create(fillStroke, fadeOutInfo, {Transparency = 1}):Play()
    TweenService:Create(glowFrame, fadeOutInfo, {ImageTransparency = 1}):Play()
    
    -- Fade out âm thanh
    TweenService:Create(loadSound, fadeOutInfo, {Volume = 0}):Play()

    task.wait(0.5)
    rgbConnection:Disconnect()
    loadSound:Destroy()
    loadGui:Destroy()

    if onComplete then
        onComplete()
    end
end

