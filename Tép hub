-- // TokaiHub - Roblox UI Library // --
-- // Pink Genshin-inspired aesthetic // --

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")
local Players = game:GetService("Players")

local startTime = os.time()
_G.ToggleKey = Enum.KeyCode.RightControl
local isLocked = false

local DISCORD = "https://discord.gg/nn783R2fK2"

local function CleanupOldUI()
    local oldUI = (gethui and gethui():FindFirstChild("TOKAIHUB")) or game.CoreGui:FindFirstChild("TOKAIHUB")
    if oldUI then oldUI:Destroy() end
end
CleanupOldUI()

local function PlayClickSound()
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://126347354635406"
    sound.Volume = 0.6
    sound.Parent = SoundService
    sound:Play()
    game:GetService("Debris"):AddItem(sound, 2)
end

local Library = {}

function Library:CreateWindow()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TOKAIHUB"
    screenGui.Parent = (gethui and gethui()) or game.CoreGui
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true

    local openSound = Instance.new("Sound")
    openSound.SoundId = "rbxassetid://90621979353525"
    openSound.Volume = 1
    openSound.Parent = SoundService
    openSound:Play()
    game:GetService("Debris"):AddItem(openSound, 5)

    local MainColor = Color3.fromRGB(255, 182, 193)
    local TextColor = Color3.fromRGB(90, 45, 55)
    local DarkPink  = Color3.fromRGB(235, 110, 140)
    local LightPink = Color3.fromRGB(220, 180, 190)

    -- Open Button
    local openBtn = Instance.new("ImageButton", screenGui)
    openBtn.Name = "OpenButton"
    openBtn.Size = UDim2.new(0, 50, 0, 50)
    openBtn.Position = UDim2.new(0, 10, 0.5, -25)
    openBtn.BackgroundColor3 = MainColor
    openBtn.Image = "rbxthumb://type=Asset&id=99217897221957&w=420&h=420"
    openBtn.Visible = false
    Instance.new("UICorner", openBtn).CornerRadius = UDim.new(1, 0)
    local openStroke = Instance.new("UIStroke", openBtn)
    openStroke.Thickness = 3

    -- Main Frame
    local main = Instance.new("Frame")
    main.Name = "MainFrame"
    main.Size = UDim2.new(0, 390, 0, 240)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.BackgroundColor3 = MainColor
    main.BackgroundTransparency = 0.3
    main.Parent = screenGui
    main.ClipsDescendants = false
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 15)
    local mainStroke = Instance.new("UIStroke", main)
    mainStroke.Thickness = 2

    -- ─── TOOLBAR ───
    local toolbar = Instance.new("Frame", main)
    toolbar.Size = UDim2.new(0, 30, 0, 95)
    toolbar.Position = UDim2.new(1, 5, 0, 10)
    toolbar.BackgroundColor3 = Color3.new(1, 1, 1)
    toolbar.BackgroundTransparency = 0.5
    Instance.new("UICorner", toolbar).CornerRadius = UDim.new(0, 8)
    local toolLayout = Instance.new("UIListLayout", toolbar)
    toolLayout.Padding = UDim.new(0, 5)
    toolLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    toolLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    local function CreateToolBtn(text, color)
        local b = Instance.new("TextButton", toolbar)
        b.Size = UDim2.new(0, 22, 0, 22)
        b.BackgroundColor3 = color or DarkPink
        b.Text = text
        b.TextColor3 = Color3.new(1, 1, 1)
        b.Font = Enum.Font.GothamBold
        b.TextSize = 13
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 5)
        return b
    end

    local closeBtn = CreateToolBtn("-",  Color3.fromRGB(235, 80, 80))
    local lockBtn  = CreateToolBtn("🔓", Color3.fromRGB(80, 200, 80))
    local keyBtn   = CreateToolBtn("⌨",  DarkPink)

    -- ─── TOGGLE / LOCK / KEYBIND ───
    local isToggling = false
    local function ToggleUI()
        if isToggling then return end
        isToggling = true
        if main.Visible then
            local tw = TweenService:Create(main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,0)})
            tw:Play()
            tw.Completed:Connect(function()
                main.Visible = false
                openBtn.Visible = true
                isToggling = false
            end)
        else
            openBtn.Visible = false
            main.Visible = true
            main.Size = UDim2.new(0,0,0,0)
            local tw = TweenService:Create(main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,390,0,240)})
            tw:Play()
            tw.Completed:Connect(function() isToggling = false end)
        end
    end

    closeBtn.MouseButton1Click:Connect(function() PlayClickSound(); ToggleUI() end)
    lockBtn.MouseButton1Click:Connect(function()
        PlayClickSound()
        isLocked = not isLocked
        lockBtn.Text = isLocked and "🔒" or "🔓"
        lockBtn.BackgroundColor3 = isLocked and Color3.fromRGB(200,80,80) or Color3.fromRGB(80,200,80)
    end)

    local isBinding = false
    keyBtn.MouseButton1Click:Connect(function()
        if isBinding then return end
        PlayClickSound(); isBinding = true; keyBtn.Text = "..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                _G.ToggleKey = input.KeyCode
                keyBtn.Text = "⌨"; isBinding = false; conn:Disconnect()
            end
        end)
    end)

    -- Animated stroke
    coroutine.wrap(function()
        local cols = {Color3.fromRGB(255,255,255), Color3.fromRGB(255,192,203), Color3.fromRGB(230,190,255)}
        while task.wait() do
            local t = (math.sin(tick()*2)+1)/2
            local c = cols[1]:Lerp(cols[2],t):Lerp(cols[3],(math.cos(tick()*1.5)+1)/2)
            mainStroke.Color = c
            openStroke.Color = c
        end
    end)()

    openBtn.MouseButton1Click:Connect(function() PlayClickSound(); ToggleUI() end)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == _G.ToggleKey then PlayClickSound(); ToggleUI() end
    end)

    -- Drag
    local function EnableDrag(obj)
        local dragging, dragInput, dragStart, startPos
        obj.InputBegan:Connect(function(input)
            if isLocked then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = obj.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        obj.InputChanged:Connect(function(input)
            if isLocked then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging and not isLocked then
                local d = input.Position - dragStart
                obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
            end
        end)
    end
    EnableDrag(main); EnableDrag(openBtn)

    -- ─── SIDEBAR TABS ───
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 35, 0, 200)
    sidebar.Position = UDim2.new(1, -40, 0.5, -100)
    sidebar.BackgroundColor3 = Color3.fromRGB(255,255,255)
    sidebar.BackgroundTransparency = 0.65
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(1, 0)
    local sideLayout = Instance.new("UIListLayout", sidebar)
    sideLayout.Padding = UDim.new(0, 7)
    sideLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    sideLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    -- ─── CONTENT AREA ───
    local tabContainer = Instance.new("Frame", main)
    tabContainer.Size = UDim2.new(0, 335, 0, 215)
    tabContainer.Position = UDim2.new(0, 8, 0, 10)
    tabContainer.BackgroundTransparency = 1

    local pages = Instance.new("Frame", tabContainer)
    pages.Size = UDim2.new(1,0,1,0)
    pages.BackgroundTransparency = 1

    function Library:CreateTab(name, iconText)
        local page = Instance.new("ScrollingFrame", pages)
        page.Name = name.."Page"
        page.Size = UDim2.new(1,0,1,0)
        page.BackgroundTransparency = 1
        page.Visible = false
        page.ScrollBarThickness = 0
        page.CanvasSize = UDim2.new(0,0,0,0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local layout = Instance.new("UIGridLayout", page)
        layout.CellSize = UDim2.new(0.48, 0, 0, 35)
        layout.CellPadding = UDim2.new(0.02, 0, 0.02, 0)

        local tabBtn = Instance.new("TextButton", sidebar)
        tabBtn.Size = UDim2.new(0, 27, 0, 27)
        tabBtn.BackgroundColor3 = DarkPink
        tabBtn.BackgroundTransparency = 0.2
        tabBtn.Text = iconText or name:sub(1,1)
        tabBtn.TextScaled = true
        tabBtn.Font = Enum.Font.GothamBold
        tabBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(1,0)

        tabBtn.MouseButton1Click:Connect(function()
            PlayClickSound()
            for _, v in pairs(pages:GetChildren()) do v.Visible = false end
            page.Visible = true
        end)

        local elements = {}

        function elements:AddDashboard()
            layout:Destroy()

            local function CreateBox(size, pos, labelText, labelSide)
                local box = Instance.new("Frame", page)
                box.Size = size
                box.Position = pos
                box.BackgroundColor3 = Color3.fromRGB(255,255,255)
                box.BackgroundTransparency = 0.55
                Instance.new("UICorner", box).CornerRadius = UDim.new(0, 10)

                if labelText then
                    local bar = Instance.new("Frame", box)
                    bar.Size = UDim2.new(0, 18, 1, 0)
                    bar.BackgroundColor3 = DarkPink
                    bar.BackgroundTransparency = 0.2
                    bar.Position = (labelSide == "left") and UDim2.new(0,0,0,0) or UDim2.new(1,-18,0,0)
                    Instance.new("UICorner", bar).CornerRadius = UDim.new(0,10)
                    local lbl = Instance.new("TextLabel", bar)
                    lbl.Size = UDim2.new(1,0,1,0)
                    lbl.Text = labelText
                    lbl.Font = Enum.Font.GothamBold
                    lbl.TextColor3 = Color3.new(1,1,1)
                    lbl.TextSize = 7
                    lbl.TextWrapped = true
                    lbl.BackgroundTransparency = 1
                end
                return box
            end

            -- ── ROW 1 ──
            -- [PLAYER box: 60%] — no slide dots
            local userBox = CreateBox(
                UDim2.new(0.605, -3, 0.47, 0),
                UDim2.new(0, 0, 0, 0),
                "P\nL\nA\nY\nE\nR", "left"
            )

            local pfp = Instance.new("ImageLabel", userBox)
            pfp.Size = UDim2.new(0, 52, 0, 52)
            pfp.Position = UDim2.new(0, 24, 0.5, -26)
            pfp.Image = Players:GetUserThumbnailAsync(
                Players.LocalPlayer.UserId,
                Enum.ThumbnailType.HeadShot,
                Enum.ThumbnailSize.Size100x100
            )
            pfp.BackgroundTransparency = 1
            Instance.new("UICorner", pfp).CornerRadius = UDim.new(1,0)

            local greet = Instance.new("TextLabel", userBox)
            greet.Size = UDim2.new(0.52, 0, 0.4, 0)
            greet.Position = UDim2.new(0, 83, 0.08, 0)
            greet.Text = "The lanterns light your way~,"
            greet.Font = Enum.Font.GothamBold
            greet.TextColor3 = TextColor
            greet.TextSize = 8
            greet.TextXAlignment = Enum.TextXAlignment.Left
            greet.TextWrapped = true
            greet.BackgroundTransparency = 1

            local playerName = Instance.new("TextLabel", userBox)
            playerName.Size = UDim2.new(0.52, 0, 0.28, 0)
            playerName.Position = UDim2.new(0, 83, 0.44, 0)
            playerName.Text = Players.LocalPlayer.DisplayName
            playerName.Font = Enum.Font.GothamBold
            playerName.TextColor3 = DarkPink
            playerName.TextSize = 13
            playerName.TextXAlignment = Enum.TextXAlignment.Left
            playerName.BackgroundTransparency = 1

            local subGreet = Instance.new("TextLabel", userBox)
            subGreet.Size = UDim2.new(0.52, 0, 0.22, 0)
            subGreet.Position = UDim2.new(0, 83, 0.74, 0)
            subGreet.Text = "Welcome to TokaiHub"
            subGreet.Font = Enum.Font.Gotham
            subGreet.TextColor3 = Color3.fromRGB(160, 100, 120)
            subGreet.TextSize = 7
            subGreet.TextXAlignment = Enum.TextXAlignment.Left
            subGreet.BackgroundTransparency = 1

            -- [ABOUT box: 39%]
            local aboutBox = CreateBox(
                UDim2.new(0.385, -3, 0.47, 0),
                UDim2.new(0.615, 0, 0, 0),
                "A\nB\nO\nU\nT", "right"
            )

            local aboutDesc = Instance.new("TextLabel", aboutBox)
            aboutDesc.Size = UDim2.new(0.82, 0, 0.52, 0)
            aboutDesc.Position = UDim2.new(0.04, 0, 0.04, 0)
            aboutDesc.Text = "TokaiHub is a powerful and cute Roblox UI library. Lightweight, draggable, and customizable."
            aboutDesc.Font = Enum.Font.Gotham
            aboutDesc.TextColor3 = TextColor
            aboutDesc.TextSize = 7
            aboutDesc.TextWrapped = true
            aboutDesc.TextXAlignment = Enum.TextXAlignment.Left
            aboutDesc.BackgroundTransparency = 1

            -- Discord copy button
            local discordBtn = Instance.new("TextButton", aboutBox)
            discordBtn.Size = UDim2.new(0.82, 0, 0.3, 0)
            discordBtn.Position = UDim2.new(0.04, 0, 0.62, 0)
            discordBtn.BackgroundColor3 = Color3.fromRGB(255,255,255)
            discordBtn.BackgroundTransparency = 0.4
            discordBtn.Text = "💬 discord.gg/nn783R2fK2"
            discordBtn.Font = Enum.Font.GothamBold
            discordBtn.TextColor3 = DarkPink
            discordBtn.TextSize = 7
            discordBtn.TextWrapped = false
            discordBtn.TextScaled = false
            Instance.new("UICorner", discordBtn).CornerRadius = UDim.new(0,5)

            discordBtn.MouseButton1Click:Connect(function()
                PlayClickSound()
                if setclipboard then
                    setclipboard(DISCORD)
                    discordBtn.Text = "✓ Link đã copy!"
                    task.delay(2, function()
                        discordBtn.Text = "💬 discord.gg/nn783R2fK2"
                    end)
                else
                    discordBtn.Text = "discord.gg/nn783R2fK2"
                end
            end)

            -- ── ROW 2 ── (no music — just clock + status)
            -- [CLOCK box: 79%]
            local clockBox = CreateBox(
                UDim2.new(0.79, -3, 0.47, 0),
                UDim2.new(0, 0, 0.53, 0),
                nil, nil
            )

            local timeLabel = Instance.new("TextLabel", clockBox)
            timeLabel.Size = UDim2.new(0.68, 0, 0.42, 0)
            timeLabel.Position = UDim2.new(0.03, 0, 0.04, 0)
            timeLabel.Font = Enum.Font.GothamBold
            timeLabel.TextSize = 22
            timeLabel.TextColor3 = TextColor
            timeLabel.BackgroundTransparency = 1
            timeLabel.TextXAlignment = Enum.TextXAlignment.Left

            local ampmBox = Instance.new("Frame", clockBox)
            ampmBox.Size = UDim2.new(0, 22, 0, 11)
            ampmBox.Position = UDim2.new(0.73, 0, 0.08, 0)
            ampmBox.BackgroundColor3 = DarkPink
            Instance.new("UICorner", ampmBox).CornerRadius = UDim.new(0,4)
            local ampmLabel = Instance.new("TextLabel", ampmBox)
            ampmLabel.Size = UDim2.new(1,0,1,0)
            ampmLabel.Text = "PM"
            ampmLabel.TextColor3 = Color3.new(1,1,1)
            ampmLabel.TextSize = 8
            ampmLabel.Font = Enum.Font.GothamBold
            ampmLabel.BackgroundTransparency = 1

            local utcLabel = Instance.new("TextLabel", clockBox)
            utcLabel.Size = UDim2.new(0.48, 0, 0.2, 0)
            utcLabel.Position = UDim2.new(0.03, 0, 0.48, 0)
            utcLabel.Text = "UTC+8 / GMT+8"
            utcLabel.TextSize = 6
            utcLabel.TextColor3 = DarkPink
            utcLabel.BackgroundTransparency = 1
            utcLabel.TextXAlignment = Enum.TextXAlignment.Left

            local dateLabel = Instance.new("TextLabel", clockBox)
            dateLabel.Size = UDim2.new(0.5, 0, 0.2, 0)
            dateLabel.Position = UDim2.new(0.5, 0, 0.48, 0)
            dateLabel.Text = os.date("%A, %B %d")
            dateLabel.TextSize = 6
            dateLabel.TextColor3 = TextColor
            dateLabel.BackgroundTransparency = 1
            dateLabel.TextXAlignment = Enum.TextXAlignment.Right

            local statLine = Instance.new("TextLabel", clockBox)
            statLine.Size = UDim2.new(0.93, 0, 0.2, 0)
            statLine.Position = UDim2.new(0.03, 0, 0.7, 0)
            statLine.Text = "Exec: 1   Up: 0m 0s   Sess: 0s"
            statLine.TextSize = 6
            statLine.Font = Enum.Font.GothamBold
            statLine.TextColor3 = TextColor
            statLine.BackgroundTransparency = 1
            statLine.TextXAlignment = Enum.TextXAlignment.Left

            local viaLabel = Instance.new("TextLabel", clockBox)
            viaLabel.Size = UDim2.new(0.93, 0, 0.18, 0)
            viaLabel.Position = UDim2.new(0.03, 0, 0.85, 0)
            viaLabel.Text = "via TokaiHub"
            viaLabel.TextSize = 6
            viaLabel.Font = Enum.Font.Gotham
            viaLabel.TextColor3 = DarkPink
            viaLabel.BackgroundTransparency = 1
            viaLabel.TextXAlignment = Enum.TextXAlignment.Left

            -- [STATUS dots box: 20%]
            local statusBox = CreateBox(
                UDim2.new(0.20, -3, 0.47, 0),
                UDim2.new(0.80, 0, 0.53, 0),
                "S\nT\nA\nT\nU\nS", "right"
            )

            local dotColors = {
                Color3.fromRGB(34, 197, 94),
                Color3.fromRGB(34, 197, 94),
                Color3.fromRGB(251, 146, 60),
                Color3.fromRGB(239, 68, 68),
                Color3.fromRGB(107, 114, 128),
            }
            for i, col in ipairs(dotColors) do
                local dot = Instance.new("Frame", statusBox)
                dot.Size = UDim2.new(0, 9, 0, 9)
                dot.Position = UDim2.new(0.18, 0, 0, 9 + (i-1)*18)
                dot.BackgroundColor3 = col
                Instance.new("UICorner", dot).CornerRadius = UDim.new(1,0)
            end

            -- Live clock
            task.spawn(function()
                local sessStart = os.time()
                while task.wait(1) do
                    timeLabel.Text = os.date("%I:%M:%S")
                    ampmLabel.Text = os.date("%p")
                    dateLabel.Text = os.date("%A, %B %d")
                    local diff = os.time() - startTime
                    local sess = os.time() - sessStart
                    local execN = math.floor(diff / 12) % 8 + 1
                    statLine.Text = string.format(
                        "Exec: %d   Up: %dm %ds   Sess: %ds",
                        execN, math.floor(diff/60), diff%60, sess
                    )
                end
            end)
        end

        function elements:AddButton(text, callback)
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = Color3.fromRGB(255,255,255)
            btn.BackgroundTransparency = 0.5
            btn.Text = text
            btn.Font = Enum.Font.GothamSemibold
            btn.TextColor3 = TextColor
            btn.TextSize = 10
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,5)
            btn.MouseButton1Click:Connect(function() PlayClickSound(); callback() end)
        end

        function elements:AddToggle(text, default, callback)
            local state = default or false
            local btn = Instance.new("TextButton", page)
            btn.BackgroundColor3 = state and DarkPink or Color3.fromRGB(255,255,255)
            btn.BackgroundTransparency = 0.3
            btn.Text = (state and "[ON] " or "[OFF] ")..text
            btn.Font = Enum.Font.GothamSemibold
            btn.TextColor3 = state and Color3.new(1,1,1) or TextColor
            btn.TextSize = 10
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0,5)
            btn.MouseButton1Click:Connect(function()
                PlayClickSound()
                state = not state
                btn.BackgroundColor3 = state and DarkPink or Color3.fromRGB(255,255,255)
                btn.Text = (state and "[ON] " or "[OFF] ")..text
                btn.TextColor3 = state and Color3.new(1,1,1) or TextColor
                callback(state)
            end)
        end

        if #sidebar:GetChildren() == 1 then page.Visible = true end
        return elements
    end

    return Library
end

