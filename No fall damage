--[[
    Script: No Fall Damage with Draggable UI
    Description: Chặn sát thương khi ngã với giao diện có thể kéo thả
]]

local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local TitleLabel = Instance.new("TextLabel")
local ToggleButton = Instance.new("TextButton")
local UIStroke = Instance.new("UIStroke")
local UICorner = Instance.new("UICorner")

-- Cấu hình mặc định
_G.Config = {
    noFallDamage = false
}

-- Thiết lập ScreenGui
ScreenGui.Name = "NoFallDamageMenu"
ScreenGui.Parent = game:GetService("CoreGui") -- Đưa vào CoreGui để không bị mất khi hồi sinh
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

-- Khung chính (Main Frame)
MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
MainFrame.Position = UDim2.new(0.5, -100, 0.5, -50)
MainFrame.Size = UDim2.new(0, 200, 0, 100)
MainFrame.Active = true
MainFrame.Draggable = true -- Cho phép kéo thả (Cũ nhưng hiệu quả)

local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 10)
MainCorner.Parent = MainFrame

local MainStroke = Instance.new("UIStroke")
MainStroke.Thickness = 2
MainStroke.Color = Color3.fromRGB(60, 60, 60)
MainStroke.Parent = MainFrame

-- Tiêu đề
TitleLabel.Name = "TitleLabel"
TitleLabel.Parent = MainFrame
TitleLabel.BackgroundTransparency = 1
TitleLabel.Size = UDim2.new(1, 0, 0, 40)
TitleLabel.Font = Enum.Font.GothamBold
TitleLabel.Text = "NO FALL DAMAGE"
TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
TitleLabel.TextSize = 14

-- Nút Bật/Tắt (Toggle Button)
ToggleButton.Name = "ToggleButton"
ToggleButton.Parent = MainFrame
ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Đỏ mặc định (Tắt)
ToggleButton.Position = UDim2.new(0.1, 0, 0.5, 0)
ToggleButton.Size = UDim2.new(0.8, 0, 0, 35)
ToggleButton.Font = Enum.Font.GothamSemibold
ToggleButton.Text = "OFF"
ToggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleButton.TextSize = 14

local ButtonCorner = Instance.new("UICorner")
ButtonCorner.CornerRadius = UDim.new(0, 8)
ButtonCorner.Parent = ToggleButton

-- Logic xử lý Bật/Tắt
ToggleButton.MouseButton1Click:Connect(function()
    _G.Config.noFallDamage = not _G.Config.noFallDamage
    
    if _G.Config.noFallDamage then
        ToggleButton.Text = "ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Xanh (Bật)
    else
        ToggleButton.Text = "OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Đỏ (Tắt)
    end
end)

-- LOGIC HOOK FUNCTION (Chạy 1 lần duy nhất)
local success, err = pcall(function()
    local __oldTakeDamage
    __oldTakeDamage = hookfunction(Instance.new("Humanoid").TakeDamage, function(self, damage, ...)
        -- Kiểm tra nếu config bật THÌ chặn sát thương
        if _G.Config.noFallDamage and (damage and damage > 0) then
            -- Trong nhiều game, sát thương ngã được gửi qua TakeDamage
            -- Chúng ta có thể kiểm tra thêm trạng thái nhân vật nếu muốn kỹ hơn
            return
        end
        return __oldTakeDamage(self, damage, ...)
    end)
end)

if not success then
    warn("Lỗi Hook: Script này yêu cầu một Executor hỗ trợ hookfunction (như Synapse, Fluxus, Delta...)")
end

-- Thông báo cho người dùng
print("No Fall Damage UI đã sẵn sàng!")
