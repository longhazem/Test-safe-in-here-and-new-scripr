local Players = game:GetService('Players')
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService('Workspace')

local Camera = Workspace.CurrentCamera
local CenterPosition = Camera.ViewportSize / 2

local Drawings = {FovOutline = nil}

local Functions = {
    GetMuzzleCFrame = filtergc('function', {Name = 'GetMuzzleCFrame'}, true),
    GetRecoil = filtergc('function', {Name = 'getRecoil'}, true)
}

function AddDrawing(Type, Properties)
    local DrawingObject = Drawing.new(Type)
    for Property, Value in pairs(Properties) do
        DrawingObject[Property] = Value
    end
    return DrawingObject
end

-- Hàm kiểm tra tường nâng cao
local function IsVisible(TargetModel)
    if not TargetModel or not TargetModel:FindFirstChild("Head") then return false end
    
    local TargetPart = TargetModel.Head
    local Origin = Camera.CFrame.Position
    local Destination = TargetPart.Position
    
    -- Lấy danh sách các vật thể che khuất mục tiêu
    -- Các bộ phận thuộc về nhân vật người chơi (LocalPlayer) sẽ bị bỏ qua
    local IgnoreList = {LocalPlayer.Character, TargetModel}
    local ObscuringParts = Camera:GetPartsObscuringTarget({Destination}, IgnoreList)
    
    -- Nếu danh sách các vật cản trống (#ObscuringParts == 0), nghĩa là nhìn thấy được
    return #ObscuringParts == 0
end

function GetClosestNPC()
    local ClosestNPC, ClosestDistance = nil, math.huge

    -- Sử dụng GetChildren thay vì GetDescendants để tối ưu hiệu suất nếu NPC ở ngay trong Workspace
    for _, Obj in pairs(Workspace:GetDescendants()) do
        if Obj:IsA("Model") and Obj.Name == "Male" then
            local Head = Obj:FindFirstChild("Head")
            local Humanoid = Obj:FindFirstChild("Humanoid")

            if Head and Humanoid and Humanoid.Health > 0 then
                local Position, OnScreen = Camera:WorldToViewportPoint(Head.Position)
                
                -- Chỉ tiếp tục nếu mục tiêu nằm trên màn hình
                if OnScreen then
                    local Distance = (Vector2.new(Position.X, Position.Y) - CenterPosition).Magnitude
                    
                    -- Kiểm tra xem có nằm trong vòng FOV không
                    if Distance <= 180 and Distance < ClosestDistance then
                        -- Kiểm tra tường (Wall Check)
                        if IsVisible(Obj) then
                            ClosestNPC = Obj
                            ClosestDistance = Distance
                        end
                    end
                end
            end
        end
    end
    
    return ClosestNPC
end

-- FOV Circle (Vòng rỗng, không có ruột)
Drawings.FovOutline = AddDrawing('Circle', {
    Visible = true, 
    Filled = false, 
    Position = CenterPosition, 
    Radius = 180, 
    Thickness = 1.5, 
    Color = Color3.new(1, 1, 1)
})

local OldMuzzle; OldMuzzle = hookfunction(Functions.GetMuzzleCFrame, function(Self, Cast)
    local Origin, Barrel, CameraCF = OldMuzzle(Self, Cast)

    if not Cast and Origin then
        local NPC = GetClosestNPC()
        if NPC and NPC:FindFirstChild("Head") then
            -- Điều hướng đạn về phía đầu NPC
            local NewOrigin = CFrame.new(Origin.Position, NPC.Head.Position)
            return NewOrigin, Barrel, CameraCF
        end
    end

    return Origin, Barrel, CameraCF
end)

local OldRecoil; OldRecoil = hookfunction(Functions.GetRecoil, function(...)
    local Args = {...}
    if Args[1] then
        Args[1]['Barrel_Spread'] = 0
        Args[1]['RecoilForce_Tap'] = 0
    end
    return OldRecoil(unpack(Args))
end)

-- Cập nhật FOV khi màn hình thay đổi kích thước
Camera:GetPropertyChangedSignal('ViewportSize'):Connect(function()
    CenterPosition = Camera.ViewportSize / 2
    if Drawings.FovOutline then
        Drawings.FovOutline.Position = CenterPosition
    end
end)
